<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rdfresh | Distributor Inquiries</title>
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .animate-entry {
            animation: fadeIn 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
            opacity: 0;
        }

        .delay-1 {
            animation-delay: 0.1s;
        }

        .delay-2 {
            animation-delay: 0.2s;
        }
    </style>
</head>

<body class="bg-[#F8FAFC]">
    <div class="flex h-screen overflow-hidden">
        <%- include('partials/sidebar') %>

            <div class="relative flex flex-col flex-1 overflow-x-hidden overflow-y-auto">
                <%- include('partials/header') %>

                    <main class="flex-1 p-8">
                        <div class="max-w-7xl mx-auto">
                            <!-- Header Section -->
                            <div
                                class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-6 animate-entry">
                                <div>
                                    <nav class="flex mb-4" aria-label="Breadcrumb">
                                        <ol
                                            class="inline-flex items-center space-x-1 md:space-x-3 text-xs font-bold uppercase tracking-widest text-[#64748b]">
                                            <li class="inline-flex items-center">
                                                <a href="/admin/dashboard"
                                                    class="hover:text-blue-600 transition-colors">Dashboard</a>
                                            </li>
                                            <li>
                                                <div class="flex items-center">
                                                    <svg class="w-3 h-3 text-slate-300 mx-1" fill="currentColor"
                                                        viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd"
                                                            d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                                            clip-rule="evenodd"></path>
                                                    </svg>
                                                    <span class="text-slate-900">Distributor Inquiries</span>
                                                </div>
                                            </li>
                                        </ol>
                                    </nav>
                                    <h1 class="text-4xl font-black text-slate-900 tracking-tight">Partnership Inquiries
                                    </h1>
                                    <p class="text-slate-500 mt-2 font-medium">Review and manage potential distributor
                                        applications.</p>
                                </div>

                                <div class="flex items-center gap-3">
                                    <div
                                        class="bg-white p-2 rounded-2xl shadow-sm border border-slate-100 flex items-center gap-2 px-4 py-3">
                                        <div class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></div>
                                        <span class="text-xs font-black text-slate-700 uppercase tracking-widest">
                                            <%= inquiries.length %> Applications
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <!-- Tabs Section -->
                            <div class="flex items-center gap-4 mb-8 animate-entry delay-1">
                                <button onclick="switchTab('distributor')" id="tab-distributor"
                                    class="px-8 py-3 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all shadow-sm border tab-btn active-tab bg-slate-900 text-emerald-400 border-slate-900">
                                    Distributor Inquiries
                                </button>
                                <button onclick="switchTab('affiliate')" id="tab-affiliate"
                                    class="px-8 py-3 rounded-2xl font-black text-[10px] uppercase tracking-[0.2em] transition-all shadow-sm border tab-btn inactive-tab bg-white text-slate-400 border-slate-100 hover:bg-slate-50">
                                    Affiliate Inquiries
                                </button>
                            </div>

                            <!-- Distributor Inquiries Table -->
                            <div id="distributor-section" class="inquiry-section">
                                <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-[0_20px_50px_rgba(0,0,0,0.02)] overflow-hidden animate-entry delay-1">
                                    <div class="p-8 border-b border-slate-50 flex items-center justify-between flex-wrap gap-4">
                                        <div class="relative w-full md:w-96">
                                            <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none text-slate-400">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                                </svg>
                                            </div>
                                            <input type="text" onkeyup="filterTable('distributor')" id="search-distributor" placeholder="Search distributors..." class="w-full pl-12 pr-4 py-4 bg-slate-50 border border-transparent rounded-[1.5rem] focus:bg-white focus:border-blue-500 transition-all outline-none font-medium text-sm">
                                        </div>
                                    </div>
                                    <div class="p-0 overflow-x-auto">
                                        <table class="w-full text-left border-collapse" id="table-distributor">
                                            <thead>
                                                <tr class="bg-slate-50/50">
                                                    <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100">Applicant</th>
                                                    <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100">Company & Type</th>
                                                    <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100">Contact Details</th>
                                                    <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100">Date Received</th>
                                                    <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100 text-center">Status</th>
                                                    <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100 text-center">Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody class="divide-y divide-slate-50">
                                                <% if (inquiries.length === 0) { %>
                                                    <tr><td colspan="6" class="px-8 py-20 text-center text-slate-400 font-bold uppercase tracking-widest">No distributor inquiries yet</td></tr>
                                                <% } else { %>
                                                    <% inquiries.forEach((inquiry) => { %>
                                                        <tr class="group hover:bg-slate-50/50 transition-colors inquiry-row">
                                                            <td class="px-8 py-6">
                                                                <div class="flex items-center gap-4">
                                                                    <div class="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center text-white font-black text-xs shadow-md"><%= inquiry.name.charAt(0).toUpperCase() %></div>
                                                                    <div><p class="text-sm font-black text-slate-900 mb-1.5"><%= inquiry.name %></p><p class="text-[10px] font-bold text-slate-400 uppercase"><%= inquiry.email %></p></div>
                                                                </div>
                                                            </td>
                                                            <td class="px-8 py-6">
                                                                <p class="text-sm font-bold text-slate-900"><%= inquiry.businessName %></p>
                                                                <span class="text-[10px] font-bold text-blue-500 uppercase tracking-widest"><%= inquiry.businessType %></span>
                                                            </td>
                                                            <td class="px-8 py-6">
                                                                <p class="text-xs font-bold text-slate-700 mb-1"><i class="fas fa-phone mr-2 text-slate-300"></i><%= inquiry.phone %></p>
                                                                <p class="text-[10px] text-slate-400 truncate max-w-[200px]"><i class="fas fa-map-marker-alt mr-2 text-slate-300"></i><%= inquiry.address %></p>
                                                            </td>
                                                            <td class="px-8 py-6">
                                                                <p class="text-xs font-black text-slate-900"><%= new Date(inquiry.createdAt).toLocaleDateString() %></p>
                                                                <p class="text-[10px] font-bold text-slate-400 uppercase"><%= new Date(inquiry.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></p>
                                                            </td>
                                                            <td class="px-8 py-6 text-center">
                                                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[9px] font-black uppercase tracking-wider <%= inquiry.status === 'pending' ? 'bg-amber-50 text-amber-600 border border-amber-100' : inquiry.status === 'approved' ? 'bg-emerald-50 text-emerald-600 border border-emerald-100' : 'bg-rose-50 text-rose-600 border border-rose-100' %>"><%= inquiry.status %></span>
                                                            </td>
                                                            <td class="px-8 py-6">
                                                                <div class="flex items-center justify-center gap-2">
                                                                    <a href="/admin/inquiries/view/<%= inquiry.id %>?type=distributor" class="p-2.5 bg-slate-900 text-emerald-400 rounded-xl hover:bg-emerald-500 hover:text-white transition-all shadow-md group/btn" title="View Details">
                                                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                                                    </a>
                                                                    <% if (inquiry.status === 'pending') { %>
                                                                        <form action="/admin/inquiries/approve/<%= inquiry.id %>?type=distributor" method="POST" onsubmit="return confirm('Approve this distributor inquiry?')">
                                                                            <button type="submit" class="p-2.5 bg-emerald-500 text-white rounded-xl hover:bg-emerald-600 transition-all shadow-md group/btn" title="Approve"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg></button>
                                                                        </form>
                                                                    <% } %>
                                                                    <form action="/admin/inquiries/delete/<%= inquiry.id %>?type=distributor" method="POST" onsubmit="return confirm('Remove this record?')">
                                                                        <button type="submit" class="p-2.5 bg-white text-slate-400 border border-slate-100 rounded-xl hover:bg-rose-50 hover:text-rose-600 transition-all shadow-sm" title="Delete"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg></button>
                                                                    </form>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>

                            <!-- Affiliate Inquiries Table (Hidden by default) -->
                            <div id="affiliate-section" class="inquiry-section hidden">
                                <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-[0_20px_50px_rgba(0,0,0,0.02)] overflow-hidden animate-entry delay-1">
                                    <div class="p-8 border-b border-slate-50 flex items-center justify-between flex-wrap gap-4">
                                        <div class="relative w-full md:w-96">
                                            <div class="absolute inset-y-0 left-4 flex items-center pointer-events-none text-slate-400">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                                </svg>
                                            </div>
                                            <input type="text" onkeyup="filterTable('affiliate')" id="search-affiliate" placeholder="Search affiliates..." class="w-full pl-12 pr-4 py-4 bg-slate-50 border border-transparent rounded-[1.5rem] focus:bg-white focus:border-blue-500 transition-all outline-none font-medium text-sm">
                                        </div>
                                    </div>
                                    <div class="p-0 overflow-x-auto">
                                        <table class="w-full text-left border-collapse" id="table-affiliate">
                                            <thead>
                                                <tr class="bg-slate-50/50">
                                                    <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100">Influencer</th>
                                                    <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100">Platform & Audience</th>
                                                    <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100">Social URL</th>
                                                    <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100">Date Received</th>
                                                    <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100 text-center">Status</th>
                                                    <th class="px-8 py-5 text-[10px] font-black text-slate-400 uppercase tracking-widest border-b border-slate-100 text-center">Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody class="divide-y divide-slate-50">
                                                <% if (affiliates.length === 0) { %>
                                                    <tr><td colspan="6" class="px-8 py-20 text-center text-slate-400 font-bold uppercase tracking-widest">No affiliate applications yet</td></tr>
                                                <% } else { %>
                                                    <% affiliates.forEach((affiliate) => { %>
                                                        <tr class="group hover:bg-slate-50/50 transition-colors inquiry-row">
                                                            <td class="px-8 py-6">
                                                                <div class="flex items-center gap-4">
                                                                    <div class="w-10 h-10 bg-emerald-600 rounded-xl flex items-center justify-center text-white font-black text-xs shadow-md"><%= affiliate.name.charAt(0).toUpperCase() %></div>
                                                                    <div><p class="text-sm font-black text-slate-900 mb-1.5"><%= affiliate.name %></p><p class="text-[10px] font-bold text-slate-400 uppercase"><%= affiliate.email %></p></div>
                                                                </div>
                                                            </td>
                                                            <td class="px-8 py-6">
                                                                <p class="text-sm font-bold text-slate-900"><%= affiliate.platformType %></p>
                                                                <span class="text-[10px] font-bold text-emerald-500 uppercase tracking-widest"><%= affiliate.audienceSize %> Audience</span>
                                                            </td>
                                                            <td class="px-8 py-6">
                                                                <a href="<%= affiliate.websiteUrl %>" target="_blank" class="text-xs font-bold text-blue-500 hover:underline truncate max-w-[200px] block"><i class="fas fa-external-link-alt mr-2 opacity-50"></i>Visit Profile</a>
                                                            </td>
                                                            <td class="px-8 py-6">
                                                                <p class="text-xs font-black text-slate-900"><%= new Date(affiliate.createdAt).toLocaleDateString() %></p>
                                                                <p class="text-[10px] font-bold text-slate-400 uppercase"><%= new Date(affiliate.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></p>
                                                            </td>
                                                            <td class="px-8 py-6 text-center">
                                                                <span class="inline-flex items-center px-2.5 py-1 rounded-full text-[9px] font-black uppercase tracking-wider <%= affiliate.status === 'pending' ? 'bg-amber-50 text-amber-600 border border-amber-100' : affiliate.status === 'approved' ? 'bg-emerald-50 text-emerald-600 border border-emerald-100' : 'bg-rose-50 text-rose-600 border border-rose-100' %>"><%= affiliate.status %></span>
                                                            </td>
                                                            <td class="px-8 py-6">
                                                                <div class="flex items-center justify-center gap-2">
                                                                    <a href="/admin/inquiries/view/<%= affiliate.id %>?type=affiliate" class="p-2.5 bg-slate-900 text-emerald-400 rounded-xl hover:bg-emerald-500 hover:text-white transition-all shadow-md group/btn" title="View Details">
                                                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                                                    </a>
                                                                    <% if (affiliate.status === 'pending') { %>
                                                                        <form action="/admin/inquiries/approve/<%= affiliate.id %>?type=affiliate" method="POST" onsubmit="return confirm('Approve this affiliate application?')">
                                                                            <button type="submit" class="p-2.5 bg-emerald-500 text-white rounded-xl hover:bg-emerald-600 transition-all shadow-md group/btn" title="Approve"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg></button>
                                                                        </form>
                                                                    <% } %>
                                                                    <form action="/admin/inquiries/delete/<%= affiliate.id %>?type=affiliate" method="POST" onsubmit="return confirm('Remove this application?')">
                                                                        <button type="submit" class="p-2.5 bg-white text-slate-400 border border-slate-100 rounded-xl hover:bg-rose-50 hover:text-rose-600 transition-all shadow-sm" title="Delete"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg></button>
                                                                    </form>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </main>
            </div>
    </div>

    <script>
        function switchTab(type) {
            // Update buttons
            const distBtn = document.getElementById('tab-distributor');
            const affBtn = document.getElementById('tab-affiliate');
            
            if (type === 'distributor') {
                distBtn.classList.add('bg-slate-900', 'text-emerald-400', 'border-slate-900');
                distBtn.classList.remove('bg-white', 'text-slate-400', 'border-slate-100');
                
                affBtn.classList.remove('bg-slate-900', 'text-emerald-400', 'border-slate-900');
                affBtn.classList.add('bg-white', 'text-slate-400', 'border-slate-100');
                
                document.getElementById('distributor-section').classList.remove('hidden');
                document.getElementById('affiliate-section').classList.add('hidden');
            } else {
                affBtn.classList.add('bg-slate-900', 'text-emerald-400', 'border-slate-900');
                affBtn.classList.remove('bg-white', 'text-slate-400', 'border-slate-100');
                
                distBtn.classList.remove('bg-slate-900', 'text-emerald-400', 'border-slate-900');
                distBtn.classList.add('bg-white', 'text-slate-400', 'border-slate-100');
                
                document.getElementById('affiliate-section').classList.remove('hidden');
                document.getElementById('distributor-section').classList.add('hidden');
            }
        }

        function filterTable(type) {
            const input = document.getElementById(`search-${type}`);
            const term = input.value.toLowerCase();
            const rows = document.querySelectorAll(`#table-${type} .inquiry-row`);
            
            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                row.style.display = text.includes(term) ? '' : 'none';
            });
        }
    </script>
</body>

</html>