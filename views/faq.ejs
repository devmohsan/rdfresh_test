<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rdfresh | FAQ Management</title>
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="bg-[#F8FAFC]">
    <div class="flex h-screen overflow-hidden">
        <%- include('partials/sidebar') %>

            <div class="relative flex flex-col flex-1 overflow-x-hidden overflow-y-auto">
                <%- include('partials/header') %>

                    <main class="flex-1 p-8">
                        <div class="max-w-7xl mx-auto">
                            <!-- Header Section -->
                            <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-6">
                                <div>
                                    <nav class="flex mb-4" aria-label="Breadcrumb">
                                        <ol
                                            class="inline-flex items-center space-x-1 md:space-x-3 text-xs font-bold uppercase tracking-widest">
                                            <li class="inline-flex items-center">
                                                <a href="/dashboard"
                                                    class="text-slate-400 hover:text-emerald-500 transition-colors">Dashboard</a>
                                            </li>
                                            <li>
                                                <div class="flex items-center">
                                                    <svg class="w-3 h-3 text-slate-300 mx-1" fill="currentColor"
                                                        viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd"
                                                            d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                                            clip-rule="evenodd"></path>
                                                    </svg>
                                                    <span class="text-slate-900">FAQ</span>
                                                </div>
                                            </li>
                                        </ol>
                                    </nav>
                                    <h1 class="text-4xl font-black text-slate-900 tracking-tight">FAQ Management</h1>
                                    <p class="text-slate-500 mt-2 font-medium">Manage frequently asked questions and
                                        answers.</p>
                                </div>

                                <div class="flex items-center gap-3">
                                    <button onclick="toggleModal('addFaqModal')"
                                        class="flex items-center gap-2 px-6 py-3 bg-emerald-500 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-emerald-600 transition-all shadow-lg shadow-emerald-200">
                                        <i class="fas fa-plus"></i>
                                        Add New FAQ
                                    </button>
                                </div>
                            </div>

                            <!-- FAQ List -->
                            <div
                                class="bg-white rounded-[2.5rem] border border-slate-100 shadow-[0_20px_50px_rgba(0,0,0,0.02)] overflow-hidden">
                                <div class="p-8 border-b border-slate-50">
                                    <h2 class="text-xl font-black text-slate-900">Active FAQ Pulse</h2>
                                </div>

                                <div class="p-0">
                                    <div class="divide-y divide-slate-50">
                                        <% if (faqs.length===0) { %>
                                            <div class="px-8 py-20 text-center">
                                                <div class="flex flex-col items-center">
                                                    <div
                                                        class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center text-slate-300 mb-4">
                                                        <i class="fas fa-question-circle fa-2x"></i>
                                                    </div>
                                                    <p class="text-slate-400 font-bold uppercase tracking-widest">No FAQ
                                                        entries found</p>
                                                </div>
                                            </div>
                                            <% } else { %>
                                                <% faqs.forEach((faq)=> { %>
                                                    <div class="group px-8 py-6 hover:bg-slate-50/50 transition-colors">
                                                        <div class="flex items-start justify-between gap-4">
                                                            <div class="flex-1">
                                                                <h3 class="text-lg font-black text-slate-900 mb-2">
                                                                    <%= faq.question %>
                                                                </h3>
                                                                <p
                                                                    class="text-slate-500 font-medium leading-relaxed max-w-3xl">
                                                                    <%= faq.answer.length> 100 ? faq.answer.substring(0,
                                                                        100) + '...' : faq.answer %>
                                                                </p>
                                                            </div>
                                                            <div
                                                                class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                                                <button data-id="<%= faq.id %>"
                                                                    data-question="<%= faq.question %>"
                                                                    data-answer="<%= faq.answer %>"
                                                                    onclick="prepareEdit(this)"
                                                                    class="p-2.5 bg-white text-slate-400 border border-slate-100 rounded-xl hover:bg-emerald-50 hover:text-emerald-600 transition-all shadow-sm">
                                                                    <i class="fas fa-edit"></i>
                                                                </button>
                                                                <button onclick="deleteFaq('<%= faq.id %>')"
                                                                    class="p-2.5 bg-white text-slate-400 border border-slate-100 rounded-xl hover:bg-rose-50 hover:text-rose-600 transition-all shadow-sm">
                                                                    <i class="fas fa-trash"></i>
                                                                </button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <% }); %>
                                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </main>
            </div>
    </div>

    <!-- Add FAQ Modal -->
    <div id="addFaqModal"
        class="fixed inset-0 z-[60] hidden bg-slate-900/40 backdrop-blur-sm flex items-center justify-center p-4">
        <div class="bg-white rounded-[2.5rem] w-full max-w-lg shadow-2xl relative overflow-hidden">
            <div class="p-8 border-b border-slate-50">
                <h2 class="text-2xl font-black text-slate-900">Add New FAQ</h2>
                <p class="text-slate-400 text-xs font-bold uppercase tracking-widest mt-1">Configure diagnostic data</p>
            </div>
            <form action="/faq/add" method="POST" class="p-8 space-y-6">
                <div>
                    <label
                        class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 px-1">Question
                        Pulse</label>
                    <input type="text" name="question" required
                        class="w-full px-6 py-4 bg-slate-50 border border-transparent rounded-2xl focus:bg-white focus:border-emerald-500 transition-all outline-none font-medium">
                </div>
                <div>
                    <label
                        class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 px-1">Answer
                        Matrix (100 char recommended)</label>
                    <textarea name="answer" required rows="4"
                        class="w-full px-6 py-4 bg-slate-50 border border-transparent rounded-2xl focus:bg-white focus:border-emerald-500 transition-all outline-none font-medium"></textarea>
                </div>
                <div class="flex gap-3 pt-2">
                    <button type="button" onclick="toggleModal('addFaqModal')"
                        class="flex-1 py-4 bg-slate-50 text-slate-500 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-slate-100 transition-all">
                        Cancel
                    </button>
                    <button type="submit"
                        class="flex-1 py-4 bg-emerald-500 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-emerald-600 transition-all shadow-lg shadow-emerald-200">
                        Create
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit FAQ Modal -->
    <div id="editFaqModal"
        class="fixed inset-0 z-[60] hidden bg-slate-900/40 backdrop-blur-sm flex items-center justify-center p-4">
        <div class="bg-white rounded-[2.5rem] w-full max-w-lg shadow-2xl relative overflow-hidden">
            <div class="p-8 border-b border-slate-50">
                <h2 class="text-2xl font-black text-slate-900">Edit FAQ Pulse</h2>
                <p class="text-slate-400 text-xs font-bold uppercase tracking-widest mt-1">Update diagnostic data</p>
            </div>
            <form id="editFaqForm" method="POST" class="p-8 space-y-6">
                <div>
                    <label
                        class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 px-1">Question</label>
                    <input type="text" id="editQuestion" name="question" required
                        class="w-full px-6 py-4 bg-slate-50 border border-transparent rounded-2xl focus:bg-white focus:border-emerald-500 transition-all outline-none font-medium">
                </div>
                <div>
                    <label
                        class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2 px-1">Answer
                    </label>
                    <textarea id="editAnswer" name="answer" required rows="4"
                        class="w-full px-6 py-4 bg-slate-50 border border-transparent rounded-2xl focus:bg-white focus:border-emerald-500 transition-all outline-none font-medium"></textarea>
                </div>
                <div class="flex gap-3 pt-2">
                    <button type="button" onclick="toggleModal('editFaqModal')"
                        class="flex-1 py-4 bg-slate-50 text-slate-500 rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-slate-100 transition-all">
                        Cancel
                    </button>
                    <button type="submit"
                        class="flex-1 py-4 bg-emerald-500 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-emerald-600 transition-all shadow-lg shadow-emerald-200">
                        Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function toggleModal(modalId) {
            const modal = document.getElementById(modalId);
            modal.classList.toggle('hidden');
        }

        function prepareEdit(btn) {
            const id = btn.getAttribute('data-id');
            const question = btn.getAttribute('data-question');
            const answer = btn.getAttribute('data-answer');
            editFaq(id, question, answer);
        }

        function editFaq(id, question, answer) {
            document.getElementById('editFaqForm').action = `/faq/edit/${id}`;
            document.getElementById('editQuestion').value = question;
            document.getElementById('editAnswer').value = answer;
            toggleModal('editFaqModal');
        }

        function deleteFaq(id) {
            Swal.fire({
                title: 'EXECUTE DELETION?',
                text: 'This FAQ will be permanently Deleted.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#f43f5e',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'DELETE DATA',
                customClass: {
                    popup: 'rounded-[1.5rem] border-none shadow-2xl',
                    confirmButton: 'rounded-xl px-8 py-3 font-black text-xs uppercase tracking-widest',
                    cancelButton: 'rounded-xl px-8 py-3 font-black text-xs uppercase tracking-widest'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = `/faq/delete/${id}`;
                }
            });
        }
    </script>

    <%- include('partials/script') %>
</body>

</html>