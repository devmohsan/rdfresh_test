<!-- Remove Item Confirmation Modal -->
<div id="removeModal"
    class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[200] opacity-0 pointer-events-none transition-all duration-300 flex items-center justify-center">
    <div id="removeModalContent"
        class="bg-white rounded-[3rem] p-10 max-w-md w-full mx-4 shadow-2xl transform scale-95 transition-all duration-300 relative overflow-hidden">
        <div class="relative z-10">
            <div class="w-20 h-20 bg-rose-50 rounded-[2rem] flex items-center justify-center mx-auto mb-8">
                <svg class="w-10 h-10 text-rose-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                        d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
            </div>
            <h3 class="text-3xl font-black text-slate-900 text-center mb-4 tracking-tight">Remove Item?</h3>
            <p class="text-slate-500 text-center mb-10 font-medium leading-relaxed">This item will be removed from your
                selection. You can always add it back from the shop.</p>
            <div class="flex gap-4">
                <button onclick="closeRemoveModal()"
                    class="flex-1 py-4 px-6 bg-slate-100 hover:bg-slate-200 text-slate-700 font-black text-xs uppercase tracking-widest rounded-2xl transition-all">
                    Cancel
                </button>
                <button onclick="confirmRemove()"
                    class="flex-1 py-4 px-6 bg-rose-500 hover:bg-rose-600 text-white font-black text-xs uppercase tracking-widest rounded-2xl transition-all shadow-xl shadow-rose-500/20">
                    Remove
                </button>
            </div>
        </div>
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-rose-50 rounded-full blur-2xl"></div>
    </div>
</div>

<!-- Clear Cart Confirmation Modal -->
<div id="clearCartModal"
    class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[200] opacity-0 pointer-events-none transition-all duration-300 flex items-center justify-center">
    <div id="clearCartModalContent"
        class="bg-white rounded-[3rem] p-10 max-w-md w-full mx-4 shadow-2xl transform scale-95 transition-all duration-300 relative overflow-hidden">
        <div class="relative z-10">
            <div class="w-20 h-20 bg-amber-50 rounded-[2rem] flex items-center justify-center mx-auto mb-8">
                <svg class="w-10 h-10 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                        d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
            </div>
            <h3 class="text-3xl font-black text-slate-900 text-center mb-4 tracking-tight">Clear Cart?</h3>
            <p class="text-slate-500 text-center mb-10 font-medium leading-relaxed">This will remove all items from your
                current session. This action cannot be undone.</p>
            <div class="flex gap-4">
                <button onclick="closeClearCartModal()"
                    class="flex-1 py-4 px-6 bg-slate-100 hover:bg-slate-200 text-slate-700 font-black text-xs uppercase tracking-widest rounded-2xl transition-all">
                    Cancel
                </button>
                <button onclick="confirmClearCart()"
                    class="flex-1 py-4 px-6 bg-rose-500 hover:bg-rose-600 text-white font-black text-xs uppercase tracking-widest rounded-2xl transition-all shadow-xl shadow-rose-500/20">
                    Empty Cart
                </button>
            </div>
        </div>
        <div class="absolute -top-10 -right-10 w-32 h-32 bg-amber-50 rounded-full blur-2xl"></div>
    </div>
</div>