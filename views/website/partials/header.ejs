<script>
    const navbar = document.getElementById('mainNav');
    const navLogo = document.getElementById('navLogo');
    const mobileMenuBtn = document.getElementById('mobileMenuBtn');
    const closeMenuBtn = document.getElementById('closeMenuBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    const mobileMenuContent = mobileMenu.querySelector('div');

    function toggleMenu() {
        const isOpen = !mobileMenu.classList.contains('opacity-0');
        if (!isOpen) {
            mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
            mobileMenuContent.classList.remove('translate-x-full');
            document.body.style.overflow = 'hidden';
        } else {
            mobileMenu.classList.add('opacity-0', 'pointer-events-none');
            mobileMenuContent.classList.add('translate-x-full');
            document.body.style.overflow = '';
        }
    }

    mobileMenuBtn.addEventListener('click', toggleMenu);
    closeMenuBtn?.addEventListener('click', toggleMenu);

    mobileMenu.addEventListener('click', (e) => {
        if (e.target === mobileMenu) toggleMenu();
    });

    mobileMenu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
            if (!mobileMenu.classList.contains('opacity-0')) toggleMenu();
        });
    });

    // Unified Scroll Effect
    const updateHeader = () => {
        const isScrolled = window.scrollY > 50;
        const width = window.innerWidth;

        if (isScrolled) {
            navbar.classList.add('py-4', 'bg-white/90', 'backdrop-blur-2xl', 'border-b', 'border-slate-100', 'shadow-sm');
            navbar.classList.remove('py-6', 'lg:py-8', 'bg-transparent');

            if (width < 640) navLogo.style.height = '32px';
            else if (width < 1024) navLogo.style.height = '38px';
            else navLogo.style.height = '42px';
        } else {
            navbar.classList.remove('py-4', 'bg-white/90', 'backdrop-blur-2xl', 'border-b', 'border-slate-100', 'shadow-sm');
            navbar.classList.add('py-6', 'lg:py-8', 'bg-transparent');
            navLogo.style.height = '';
        }
    };

    window.addEventListener('scroll', updateHeader);
    window.addEventListener('resize', updateHeader);

    // Global Cart Count Update
    async function updateCartCount() {
        try {
            const response = await fetch('/cart/count');
            if (response.status === 401) return;
            const data = await response.json();
            const cartBadge = document.getElementById('cart-count');
            const mobileCartBadge = document.getElementById('cart-count-mobile'); // Matched with HTML ID

            if (data.count !== undefined) {
                if (cartBadge) {
                    cartBadge.textContent = data.count;
                    if (data.count > 0) cartBadge.classList.remove('hidden');
                    else cartBadge.classList.add('hidden');
                }
                if (mobileCartBadge) {
                    mobileCartBadge.textContent = data.count;
                    if (data.count > 0) mobileCartBadge.classList.remove('hidden');
                    else mobileCartBadge.classList.add('hidden');
                }
            }
        } catch (error) { }
    }

    document.addEventListener('DOMContentLoaded', updateCartCount);
</script>

<style>
    /* Prevent layout shift and overflow */
    @media (max-width: 480px) {
        .xs\:hidden {
            display: none;
        }

        .xs\:inline {
            display: inline;
        }
    }

    @media (min-width: 481px) {
        .xs\:hidden {
            display: none !important;
        }

        .xs\:inline {
            display: inline !important;
        }
    }

    /* Ensure the shop button text is handled correctly */
    @media (max-width: 380px) {
        #navLogo {
            max-width: 100px;
        }
    }

    /* Scrollbar Styling for Sidebar */
    .custom-scrollbar::-webkit-scrollbar {
        width: 3px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #e2e8f0;
        border-radius: 10px;
    }
</style>