            <%- include('partials/footer') %>

                <style>
                    @keyframes slide-in {
                        from {
                            transform: translateX(400px);
                            opacity: 0;
                        }

                        to {
                            transform: translateX(0);
                            opacity: 1;
                        }
                    }

                    .animate-slide-in {
                        animation: slide-in 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
                    }

                    .reveal {
                        opacity: 0;
                        transform: translateY(20px);
                        transition: all 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
                    }

                    .reveal.active {
                        opacity: 1;
                        transform: translateY(0);
                    }
                </style>

                <script>
                    // Scroll Reveal logic
                    function reveal() {
                        const reveals = document.querySelectorAll(".reveal");
                        reveals.forEach(el => {
                            const windowHeight = window.innerHeight;
                            const elementTop = el.getBoundingClientRect().top;
                            const elementVisible = 150;
                            if (elementTop < windowHeight - elementVisible) {
                                el.classList.add("active");
                            }
                        });
                    }
                    window.addEventListener("scroll", reveal);
                    window.addEventListener("load", reveal);

                    document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
                        btn.addEventListener('click', async (e) => {
                        <% if (!user) { %>
                                window.location.href = '/login';
                                return;
                        <% } %>

                        const productId = btn.getAttribute('data-id');
                            const productName = btn.getAttribute('data-name');
                            const price = btn.getAttribute('data-price');
                            const image = btn.getAttribute('data-image');

                            try {
                                const response = await fetch('/cart/add', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ productId, productName, price, image, quantity: 1 })
                                });

                                const data = await response.json();

                                if (response.status === 401) {
                                    alert(data.message || 'Please login to add items to cart');
                                    window.location.href = data.redirectTo || '/login';
                                    return;
                                }

                                if (data.success) {
                                    // Show toast
                                    const toast = document.createElement('div');
                                    toast.className = 'fixed top-24 right-6 bg-blue-600 text-white px-8 py-5 rounded-[2rem] shadow-2xl z-50 flex items-center gap-4 animate-slide-in border border-white/10 backdrop-blur-xl';
                                    toast.innerHTML = `
                                    <div class="w-10 h-10 rounded-xl bg-white/20 flex items-center justify-center shrink-0">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="font-black text-sm uppercase tracking-wider">${productName}</p>
                                        <p class="text-xs font-bold text-blue-100/80">Inventory updated. Heading to cart...</p>
                                    </div>
                                `;
                                    document.body.appendChild(toast);

                                    setTimeout(() => {
                                        window.location.href = '/cart';
                                    }, 1500);
                                } else {
                                    alert(data.message || 'Error adding to cart');
                                }
                            } catch (error) {
                                console.error('Error:', error);
                                alert('Error adding to cart. Please try again.');
                            }
                        });
                    });

