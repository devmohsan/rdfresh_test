<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>

    <body class="bg-white text-secondary overflow-x-hidden selection:bg-primary/30">

        <%- include('partials/header') %>

            <!-- Decorative Background Elements -->
            <div class="fixed inset-0 pointer-events-none -z-10 overflow-hidden">
                <div
                    class="absolute -top-[10%] -right-[10%] w-[400px] h-[400px] bg-primary/5 rounded-full blur-[120px] animate-pulse">
                </div>
                <div class="absolute top-[20%] -left-[10%] w-[300px] h-[300px] bg-primary/5 rounded-full blur-[100px]">
                </div>
            </div>

            <main class="pt-40 pb-24 relative">
                <section class="container mx-auto px-6 max-w-8xl">
                    <div class="mb-20 flex flex-col md:flex-row md:items-end justify-between gap-8 reveal">
                        <div class="max-w-2xl">
                            <div class="inline-block px-4 py-1.5 bg-primary/10 rounded-full mb-6">
                                <p class="text-[10px] font-black text-primary tracking-[0.3em] uppercase">Core
                                    Collection</p>
                            </div>
                            <h1
                                class="text-4xl sm:text-6xl md:text-8xl font-black text-secondary tracking-tighter leading-[0.8] mb-8 uppercase">
                                Professional <br><span class="text-primary italic">Solutions.</span>
                            </h1>
                            <p class="text-slate-500 font-bold text-xl uppercase tracking-widest leading-relaxed">
                                Precision-engineered atmosphere control for high-performance commercial refrigeration.
                            </p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
                        <% if (products && products.length> 0) { %>
                            <% products.forEach(product=> { %>
                                <!-- Product Card -->
                                <div
                                    class="bg-white rounded-[3rem] overflow-hidden shadow-xl shadow-slate-200/50 border border-slate-100 group flex flex-col transition-all duration-500 hover:shadow-2xl hover:-translate-y-2">
                                    <div class="h-72 bg-slate-50 relative overflow-hidden">
                                        <% const img=product.imageUrl
                                            || 'https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&fit=crop&q=80&w=600'
                                            ; const price=parseFloat(product.price || 0).toFixed(2); %>
                                            <a href="/product/<%= product.productId %>" class="block w-full h-full">
                                                <img src="<%= img %>" alt="<%= product.name %>" loading="lazy"
                                                    class="product-image cursor-pointer w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000 opacity-90 group-hover:opacity-100">
                                            </a>
                                            <div
                                                class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-40 pointer-events-none">
                                            </div>
                                    </div>
                                    <div class="p-10 flex-grow flex flex-col">
                                        <div class="flex justify-between items-start mb-6">
                                            <div class="flex-grow pr-4">
                                                <h3
                                                    class="text-2xl font-black text-secondary mb-2 leading-tight group-hover:text-primary transition-colors uppercase">
                                                    <%= product.name %> - <%= product.description.substring(0, 25) %>
                                                </h3>
                                                <div
                                                    class="inline-block px-3 py-1 bg-slate rounded-lg border border-slate-100">
                                                    <p
                                                        class="text-[10px] font-black text-slate-400 uppercase tracking-widest">
                                                        SKU: <%= product.sku %>
                                                    </p>
                                                </div>
                                            </div>

                                            <div class="text-right">
                                                <p class="text-3xl font-black text-secondary tracking-tighter">$<%=
                                                        price %>
                                                </p>
                                            </div>
                                        </div>
                                        <p class="text-slate-500 font-medium text-sm mb-10 leading-relaxed flex-grow">
                                            <%= product.description
                                                || 'High-performance refrigeration solution designed for professional commercial storage environments.'
                                                %>
                                        </p>
                                        <button
                                            class="add-to-cart-btn w-full py-5 bg-secondary text-white font-black text-[11px] uppercase tracking-[0.2em] rounded-2xl hover:bg-primary hover:text-white hover:shadow-xl hover:shadow-primary/20 transition-all duration-500"
                                            data-id="<%= product.productId %>" data-name="<%= product.name %>"
                                            data-price="<%= product.price || 0 %>"
                                            data-image="<%= product.imageUrl || 'https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&fit=crop&q=80&w=600' %>">
                                            Add to Cart
                                        </button>
                                    </div>
                                </div>
                                <% }) %>
                                    <% } else { %>
                                        <!-- Empty State -->
                                        <div
                                            class="col-span-full py-32 text-center bg-slate-50 rounded-[4rem] border border-slate-100 relative overflow-hidden">
                                            <div
                                                class="absolute -top-10 -right-10 w-40 h-40 bg-primary/5 rounded-full blur-3xl">
                                            </div>
                                            <div
                                                class="w-24 h-24 bg-primary/10 rounded-[2rem] flex items-center justify-center mx-auto mb-8 border border-primary/10 rotate-3">
                                                <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2.5"
                                                        d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4">
                                                    </path>
                                                </svg>
                                            </div>
                                            <h2
                                                class="text-5xl font-black text-secondary mb-4 tracking-tighter uppercase">
                                                Vessels are
                                                empty.</h2>
                                            <p
                                                class="text-slate-500 font-bold uppercase tracking-widest text-lg max-w-md mx-auto mb-10">
                                                We're
                                                currently replenishing our stock. Explore our technology while you wait.
                                            </p>
                                            <a href="/"
                                                class="inline-flex items-center gap-3 px-8 py-4 bg-primary text-white font-black text-[11px] uppercase tracking-widest rounded-2xl hover:bg-secondary hover:text-white transition-all duration-500">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                                                </svg>
                                                Return to Port
                                            </a>
                                        </div>
                                        <% } %>
                    </div>
                </section>
            </main>

