                <!-- Document Viewer Modal -->
                <div id="documentModal"
                    class="fixed inset-0 z-[160] hidden flex-col items-center justify-center p-4 md:p-8 backdrop-blur-md bg-slate-900/80 transition-all duration-300 opacity-0">
                    <div class="absolute inset-0" onclick="closeDocumentModal()"></div>
                    <div class="relative w-full max-w-6xl max-h-[90vh] rounded-[2rem] shadow-2xl flex flex-col bg-white overflow-hidden transform scale-95 transition-transform duration-300 delay-100"
                        id="documentModalContent">

                        <!-- Header -->
                        <div class="flex items-center justify-between p-6 border-b border-slate-100 bg-white z-20">
                            <div class="flex items-center gap-4">
                                <div
                                    class="w-10 h-10 rounded-xl bg-primary/10 text-primary flex items-center justify-center">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                    </svg>
                                </div>
                                <div>
                                    <h3 id="documentModalTitle"
                                        class="text-xl font-black text-secondary uppercase tracking-tight">Document
                                        Preview</h3>
                                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Secure
                                        Viewer</p>
                                </div>
                            </div>

                            <div class="flex items-center gap-3">
                                <a id="documentModalDownload" href="#" download
                                    class="p-3 text-slate-400 hover:text-primary hover:bg-primary/5 rounded-xl transition-all"
                                    title="Download Document">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                                    </svg>
                                </a>
                                <button onclick="closeDocumentModal()"
                                    class="p-3 text-slate-400 hover:text-rose-500 hover:bg-rose-50 rounded-xl transition-all">
                                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                            d="M6 18L18 6M6 6l12 12" />
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <!-- Viewer Area -->
                        <div
                            class="relative flex-grow overflow-auto bg-slate-100 p-4 md:p-8 flex items-center justify-center min-h-[50vh]">

                            <!-- Loading State -->
                            <div id="documentLoading"
                                class="absolute inset-0 flex items-center justify-center bg-slate-100 z-10 transition-opacity duration-300">
                                <div class="flex flex-col items-center gap-4">
                                    <div
                                        class="w-12 h-12 border-4 border-white border-t-primary rounded-full animate-spin shadow-lg">
                                    </div>
                                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Loading
                                        Document...</p>
                                </div>
                            </div>

                            <!-- Image Preview -->
                            <img id="documentModalImage" src="" alt="Document Preview"
                                class="max-w-full h-auto rounded-xl shadow-md opacity-0 transition-opacity duration-500"
                                onload="document.getElementById('documentLoading').classList.add('opacity-0'); setTimeout(() => document.getElementById('documentLoading').classList.add('hidden'), 300); this.classList.remove('opacity-0');" />
                        </div>
                    </div>
                </div>

                <script>
                    function openProductModal(name, image, price, sku, desc) {
                        const modal = document.getElementById('productDetailModal');
                        const modalContent = document.getElementById('productDetailContent');

                        document.getElementById('modalProductName').textContent = name;
                        document.getElementById('modalProductImage').src = image;
                        document.getElementById('modalProductPrice').textContent = price;
                        document.getElementById('modalProductSku').textContent = sku;
                        document.getElementById('modalProductDesc').textContent = desc;

                        modal.classList.remove('hidden');
                        modal.classList.add('flex');

                        setTimeout(() => {
                            modal.classList.remove('opacity-0');
                            modalContent.classList.remove('scale-95');
                            modalContent.classList.add('scale-100');
                        }, 10);

                        document.body.style.overflow = 'hidden';
                    }

                    function closeProductModal() {
                        const modal = document.getElementById('productDetailModal');
                        const modalContent = document.getElementById('productDetailContent');

                        modal.classList.add('opacity-0');
                        modalContent.classList.remove('scale-100');
                        modalContent.classList.add('scale-95');

                        setTimeout(() => {
                            modal.classList.add('hidden');
                            modal.classList.remove('flex');
                            document.body.style.overflow = '';
                        }, 300);
                    }

                    // ESC key listener for product modal
                    document.addEventListener('keydown', (e) => {
                        if (e.key === 'Escape' && !document.getElementById('productDetailModal').classList.contains('hidden')) {
                            closeProductModal();
                        }
                    });

                    function viewDocument(title, url) {
                        const modal = document.getElementById('documentModal');
                        const modalContent = document.getElementById('documentModalContent');
                        const titleEl = document.getElementById('documentModalTitle');
                        const imageEl = document.getElementById('documentModalImage');
                        const downloadEl = document.getElementById('documentModalDownload');
                        const loader = document.getElementById('documentLoading');

                        // Reset State
                        loader.classList.remove('hidden', 'opacity-0');
                        imageEl.classList.add('opacity-0');
                        imageEl.src = '';

                        // Set Content
                        titleEl.textContent = title;
                        imageEl.src = url;
                        downloadEl.href = url;

                        // Show Modal
                        modal.classList.remove('hidden');
                        // Small delay to allow display block to apply before animating opacity
                        setTimeout(() => {
                            modal.classList.remove('opacity-0');
                            modalContent.classList.remove('scale-95');
                            modalContent.classList.add('scale-100');
                        }, 10);

                        document.body.style.overflow = 'hidden'; // Prevent scrolling
                    }

                    function closeDocumentModal() {
                        const modal = document.getElementById('documentModal');
                        const modalContent = document.getElementById('documentModalContent');

                        modal.classList.add('opacity-0');
                        modalContent.classList.remove('scale-100');
                        modalContent.classList.add('scale-95');

                        // Wait for animations to finish before hiding
                        setTimeout(() => {
                            modal.classList.add('hidden');
                            document.body.style.overflow = ''; // Restore scrolling
                        }, 300);
                    }

                    // Handle ESC key to close Document Modal
                    document.addEventListener('keydown', (e) => {
                        if (e.key === 'Escape') {
                            const docModal = document.getElementById('documentModal');
                            if (docModal && !docModal.classList.contains('hidden')) {
                                closeDocumentModal();
                            }
                        }
                    });
                </script>
    </body>

</html>