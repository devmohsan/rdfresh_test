            <%- include('partials/footer') %>

                <script>
                    function openVideoModal(youtubeId, title) {
                        const modal = document.getElementById('videoModal');
                        const iframe = document.getElementById('videoIframe');
                        const loader = document.getElementById('videoLoading');

                        loader.classList.remove('hidden', 'opacity-0');
                        iframe.src = `https://www.youtube.com/embed/${youtubeId}?autoplay=1&rel=0&modestbranding=1`;

                        modal.classList.remove('hidden');
                        modal.classList.add('flex');
                        document.body.style.overflow = 'hidden';
                    }

                    function closeVideoModal() {
                        const modal = document.getElementById('videoModal');
                        const iframe = document.getElementById('videoIframe');

                        iframe.src = "";
                        modal.classList.add('hidden');
                        modal.classList.remove('flex');
                        document.body.style.overflow = '';
                    }

                    // Handle ESC key to close
                    document.addEventListener('keydown', (e) => {
                        if (e.key === 'Escape') {
                            closeVideoModal();
                        }
                    });

                    // Show popup after 5 seconds
                    setTimeout(() => {
                        const popup = document.getElementById('emailPopup');
                        if (popup && !localStorage.getItem('subscribed')) {
                            popup.classList.remove('hidden');
                        }
                    }, 5000);

                    async function handleSubscribe() {
                        const emailInput = document.getElementById('subEmail');
                        const subBtn = document.getElementById('subBtn');
                        const subContainer = document.getElementById('subContainer');
                        const email = emailInput.value;

                        if (!email || !email.includes('@')) {
                            alert('Please enter a valid email.');
                            return;
                        }

                        // UI Feedback
                        const originalText = subBtn.innerText;
                        subBtn.innerText = 'Subscribing...';
                        subBtn.disabled = true;

                        try {
                            const response = await fetch('/subscribe', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ email })
                            });

                            const data = await response.json();

                            if (data.success) {
                                subContainer.innerHTML = `<div class="text-primary font-bold bg-primary/10 p-6 rounded-2xl animate-fade-in text-center border border-primary/20">${data.message}</div>`;
                                localStorage.setItem('subscribed', 'true');
                                setTimeout(() => {
                                    document.getElementById('emailPopup').classList.add('hidden');
                                }, 3000);
                            } else {
                                alert(data.message || 'Something went wrong.');
                                subBtn.innerText = originalText;
                                subBtn.disabled = false;
                            }
                        } catch (error) {
                            console.error('Subscription error:', error);
                            alert('Failed to connect to server.');
                            subBtn.innerText = originalText;
                            subBtn.disabled = false;
                        }
                    }
                </script>
                <!-- Product Detail Modal -->
                <div id="productDetailModal"
