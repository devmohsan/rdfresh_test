            <!-- Video Viewer Modal -->
            <div id="videoModal" class="fixed inset-0 z-[150] hidden items-center justify-center p-4 md:p-8">
                <div class="absolute inset-0  backdrop-blur-sm" onclick="closeVideoModal()"></div>
                <div
                    class="relative w-full max-w-5xl aspect-video rounded-[2rem] shadow-2xl overflow-hidden animate-zoom-in">
                    <button onclick="closeVideoModal()"
                        class="absolute top-6 right-6 z-20 p-3 bg-white/10 hover:bg-white/20 text-white rounded-xl transition-all border border-white/20 backdrop-blur-md">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    </button>
                    <div id="videoLoading"
                        class="absolute inset-0 flex items-center justify-center bg-slate-950 z-10 transition-opacity">
                        <div class="flex flex-col items-center gap-4">
                            <div class="w-12 h-12 border-4 border-slate-700 border-t-primary rounded-full animate-spin">
                            </div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Buffering
                                Experience...</p>
                        </div>
                    </div>
                    <iframe id="videoIframe" class="w-full h-full border-none" src=""
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
