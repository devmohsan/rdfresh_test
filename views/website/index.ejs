                    </div>

                    <script>
                        const calcL = document.getElementById('calc-l');
                        const calcW = document.getElementById('calc-w');
                        const calcH = document.getElementById('calc-h');
                        const calcFans = document.getElementById('calc-fans');
                        const fansValDisp = document.getElementById('fans-val');

                        const resCubic = document.getElementById('res-cubic');
                        const resPanels = document.getElementById('res-panels');
                        const resFanPanelsCount = document.getElementById('res-fan-panels-count');
                        const resExtra = document.getElementById('res-extra');
                        const resExtraVal = document.getElementById('res-extra-val');
                        const resBagType = document.getElementById('res-bag-type');
                        const buyLink = document.getElementById('buy-link');
                        
                        const el = document.getElementById("data");

                        const currentUser = JSON.parse(el.dataset.user);
                        const productsFromDb = JSON.parse(el.dataset.products);

                        // const currentUser = <% - locals.user ? JSON.stringify(locals.user) : "null" %>;
                        // const productsFromDb = <% - JSON.stringify(products || []) %>;
                        const customerProducts = productsFromDb.filter(p => p.visibility === 'customer');
                        let selectedType = customerProducts[0] ? customerProducts[0].name.toLowerCase().replace(/\s+/g, '-') : 'all-in-one-cooler';

                        // Dynamic product mapping & config population
                        const productMapping = {};
                        const configs = {};

                        customerProducts.forEach(p => {
                            const type = p.name.toLowerCase().replace(/\s+/g, '-');
                            productMapping[type] = {
                                productId: p.id,
                                productName: p.name,
                                price: p.price,
                                image: p.imageUrl || '/images/products/all-in-one.png'
                            };
                            configs[type] = p.name;
                        });

                        function calculate() {
                            const l = parseFloat(calcL.value) || 0;
                            const w = parseFloat(calcW.value) || 0;
                            const h = parseFloat(calcH.value) || 0;
                            const fans = parseInt(calcFans.value) || 0;

                            const cubic = l * w * h;
                            const panelsNeeded = Math.ceil(cubic / 300);

                            resCubic.innerText = cubic.toLocaleString();
                            resPanels.innerText = panelsNeeded.toString().padStart(2, '0');
                            fansValDisp.innerText = fans;
                            resFanPanelsCount.innerText = fans.toString().padStart(2, '0') + (fans === 1 ? ' UNIT' : ' UNITS');

                            if (panelsNeeded > (fans + 1)) {
                                resExtra.classList.remove('hidden');
                                resExtraVal.innerText = (panelsNeeded - (fans + 1)).toString().padStart(2, '0') + ' UNIT';
                            } else {
                                resExtra.classList.add('hidden');
                            }

                            resBagType.innerText = configs[selectedType] || 'Standard Configuration';

                            if (cubic > 0) {
                                buyLink.classList.remove('bg-slate-100', 'text-slate-400', 'cursor-not-allowed', 'opacity-70', 'pointer-events-none');
                                buyLink.classList.add('bg-primary', 'text-white', 'shadow-[0_20px_40px_-10px_rgba(16,185,129,0.3)]', 'hover:shadow-[0_25px_50px_-12px_rgba(16,185,129,0.4)]', 'hover:-translate-y-1', 'cursor-pointer', 'opacity-100', 'pointer-events-auto');
                            } else {
                                buyLink.classList.add('bg-slate-100', 'text-slate-400', 'cursor-not-allowed', 'opacity-70', 'pointer-events-none');
                                buyLink.classList.remove('bg-primary', 'text-white', 'shadow-[0_20px_40px_-10px_rgba(16,185,129,0.3)]', 'hover:shadow-[0_25px_50px_-12px_rgba(16,185,129,0.4)]', 'hover:-translate-y-1', 'cursor-pointer', 'opacity-100', 'pointer-events-auto');
                            }
                        }

                        [calcL, calcW, calcH, calcFans].forEach(el => el.addEventListener('input', calculate));

                        document.querySelectorAll('.storage-btn').forEach(btn => {
                            btn.addEventListener('click', () => {
                                document.querySelectorAll('.storage-btn').forEach(b => {
                                    b.classList.remove('active', 'border-primary', 'bg-primary/5');
                                    b.classList.add('border-gray-100', 'bg-white');
                                    b.querySelector('p').classList.add('opacity-80');
                                });
                                btn.classList.add('active', 'border-primary', 'bg-primary/5');
                                btn.classList.remove('border-gray-100', 'bg-white');
                                btn.querySelector('p').classList.remove('opacity-80');
                                selectedType = btn.dataset.type;
                                calculate();
                            });
                        });

                        calculate();
                        // Logic moved to top of script

                        buyLink.addEventListener('click', async () => {
                            // 1. Check Login
                            if (!currentUser) {
                                window.location.href = '/login?restricted=calculator';
                                return;
                            }

                            // 2. Check Role (Only customers allowed)
                            if (currentUser.role !== 'customer') {
                                alert('This configuration tool is specifically for customers. Please visit the Distributor Command Center for professional orders.');
                                return;
                            }

                            const productInfo = productMapping[selectedType];
                            const quantity = parseInt(resPanels.innerText) || 1;

                            const originalText = buyLink.innerHTML;
                            buyLink.innerHTML = `Adding to Cart... 
                            <svg class="w-5 h-5 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                            </svg>`;

                            try {
                                const response = await fetch('/cart/add', {
                                    method: 'POST',
                                    headers: {
                                        'Content-Type': 'application/json',
                                        'Accept': 'application/json'
                                    },
                                    body: JSON.stringify({
                                        productId: productInfo.productId,
                                        productName: productInfo.productName,
                                        price: productInfo.price,
                                        image: productInfo.image,
                                        quantity: quantity
                                    })
                                });

                                const data = await response.json();

                                if (response.ok && data.success) {
                                    window.location.href = '/cart';
                                } else if (response.status === 401 && data.redirectTo) {
                                    window.location.href = data.redirectTo;
                                } else {
                                    alert(data.message || 'Error adding to cart');
                                    buyLink.innerHTML = originalText;
                                }
                            } catch (error) {
                                console.error('Add to cart error:', error);
                                alert('An error occurred. Please try again.');
                                buyLink.innerHTML = originalText;
                            }
                        });
                    </script>
