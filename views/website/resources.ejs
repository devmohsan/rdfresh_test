<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>

    <body class="bg-white text-secondary overflow-x-hidden selection:bg-primary/30">
        <%- include('partials/header') %>

            <main class="min-h-screen pt-32 pb-24 relative overflow-hidden">
                <!-- Advanced Background Decorations -->
                <div class="fixed top-0 left-0 w-full h-full -z-20 pointer-events-none opacity-40">
                    <div
                        class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-primary/5 rounded-full blur-[120px] animate-pulse">
                    </div>
                    <div
                        class="absolute bottom-[-5%] left-[-5%] w-[500px] h-[500px] bg-primary/5 rounded-full blur-[100px]">
                    </div>
                </div>

                <div class="container mx-auto px-6 max-w-8xl">
                    <!-- Premium Header -->
                    <div class="text-center mb-12 reveal">
                        <div class="inline-block px-4 py-1.5 bg-primary/10 rounded-full mb-6">
                            <p class="text-[10px] font-black text-primary tracking-[0.3em] uppercase">RD Fresh
                                Knowledge Center</p>
                        </div>
                        <h1
                            class="text-4xl sm:text-6xl md:text-8xl font-black text-secondary tracking-[0.09em] leading-[0.8] mb-8 uppercase">
                            The <span class="text-primary italic">Resource</span> Vault
                        </h1>
                        <p class="text-slate-500 font-bold uppercase tracking-widest text-lg max-w-2xl mx-auto px-4">
                            Elite technical documentation, operational guides, and training resources for facility
                            protection.
                        </p>
                    </div>

                    <!-- Modern Tab Navigation -->
                    <div class="flex justify-center mb-16 reveal px-4">
                        <div
                            class="p-2 bg-slate backdrop-blur-2xl rounded-[2.5rem] flex flex-col sm:flex-row gap-2 border border-slate-100 shadow-xl w-full sm:w-auto">
                            <button onclick="switchTab('documents')" id="tab-documents"
                                class="tab-btn active px-4 sm:px-10 py-3 sm:py-5 rounded-[2rem] text-[9px] sm:text-[11px] font-black uppercase tracking-[0.15em] sm:tracking-[0.2em] transition-all duration-500 hover:scale-[1.02] active:scale-95 w-full sm:w-auto justify-center">
                                <span class="flex items-center gap-3">
                                    <div
                                        class="w-6 h-6 rounded-lg bg-primary/10 flex items-center justify-center group-active:scale-90 transition-transform">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                        </svg>
                                    </div>
                                    Technical Vault
                                </span>
                            </button>
                            <button onclick="switchTab('videos')" id="tab-videos"
                                class="tab-btn px-4 sm:px-10 py-3 sm:py-5 rounded-[2rem] text-[9px] sm:text-[11px] font-black uppercase tracking-[0.15em] sm:tracking-[0.2em] text-slate-400 hover:text-secondary hover:bg-white/50 transition-all duration-500 hover:scale-[1.02] active:scale-95 w-full sm:w-auto justify-center">
                                <span class="flex items-center gap-3">
                                    <div class="w-6 h-6 rounded-lg bg-slate-100 flex items-center justify-center">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                                d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                                        </svg>
                                    </div>
                                    Video Library
                                </span>
                            </button>
                            <button onclick="switchTab('how-it-works')" id="tab-how-it-works"
                                class="tab-btn px-4 sm:px-10 py-3 sm:py-5 rounded-[2rem] text-[9px] sm:text-[11px] font-black uppercase tracking-[0.15em] sm:tracking-[0.2em] text-slate-400 hover:text-secondary hover:bg-white/50 transition-all duration-500 hover:scale-[1.02] active:scale-95 w-full sm:w-auto justify-center">
                                <span class="flex items-center gap-3">
                                    <div class="w-6 h-6 rounded-lg bg-slate-100 flex items-center justify-center">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                                d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a2 2 0 00-1.96 1.414l-.726 1.451a2 2 0 01-2.454.912l-1.451-.726a2 2 0 00-1.414 1.96l.477 2.387a2 2 0 00.547 1.022l1.451.726c.74.37 1.57.14 2.1-.424l1.451-1.451a2 2 0 012.828 0l1.451 1.451c.53.564 1.36.794 2.1.424l1.451-.726a2 2 0 00.547-1.022l.477-2.387a2 2 0 00-1.414-1.96l-1.451-.726a2 2 0 01-.912-2.454l.726-1.451a2 2 0 00-1.414-1.96l-2.387-.477a2 2 0 00-1.022.547l-1.451 1.451a2 2 0 01-2.828 0l-1.451-1.451z" />
                                        </svg>
                                    </div>
                                    How It Works
                                </span>
                            </button>
                            <!-- <% if (user && user.role !=='distributor' ) { %>
                                <button onclick="switchTab('affiliate')" id="tab-affiliate"
                                    class="tab-btn px-4 sm:px-10 py-3 sm:py-5 rounded-[2rem] text-[9px] sm:text-[11px] font-black uppercase tracking-[0.15em] sm:tracking-[0.2em] text-slate-400 hover:text-secondary hover:bg-white/50 transition-all duration-500 hover:scale-[1.02] active:scale-95 w-full sm:w-auto justify-center">
                                    <span class="flex items-center gap-3">
                                        <div class="w-6 h-6 rounded-lg bg-slate-100 flex items-center justify-center">
                                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor"
                                                viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                                            </svg>
                                        </div>
                                        Vegiefresh Affiliate
                                    </span>
                                </button>
                                <% } %> -->
                        </div>
                    </div>

                    <!-- Tab Contents -->
                    <div id="tab-content" class="">
                        <!-- DOCUMENTS TAB -->
                        <div id="content-documents" class="tab-pane active animate-fade-in">
                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                                <% if (typeof sections !=='undefined' && sections.length> 0) { %>
                                    <% sections.forEach((section, index)=> { %>
                                        <div
                                            class="<%= index === 0 ? 'lg:col-span-2' : '' %> bg-white rounded-[3rem] p-8 md:p-12 shadow-xl border border-slate-100 reveal">
                                            <div
                                                class="flex items-center justify-between mb-10 pb-6 border-b border-slate-100">
                                                <h3
                                                    class="text-3xl font-black text-secondary flex items-center gap-4 tracking-tighter uppercase italic">
                                                    <div
                                                        class="w-12 h-12 rounded-2xl bg-primary text-white flex items-center justify-center shadow-lg shadow-primary/20">
                                                        <svg class="w-6 h-6" fill="none" stroke="currentColor"
                                                            viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                                stroke-width="2.5"
                                                                d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.247 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                                                        </svg>
                                                    </div>
                                                    <%= section.title %>
                                                </h3>
                                            </div>

                                            <div
                                                class="grid grid-cols-1 <%= index === 0 ? 'md:grid-cols-2' : '' %> gap-4">
                                                <% section.documents.forEach(doc=> { %>
                                                    <% const isPdf=doc.fileName.toLowerCase().endsWith('.pdf'); const
                                                        isImage=/\.(jpg|jpeg|png|webp)$/i.test(doc.fileName); const
                                                        fileType=isPdf ? 'PDF' : (isImage ? 'IMG' : 'DOC' ); const
                                                        typeColor=isPdf ? 'rose' : (isImage ? 'emerald' : 'blue' ); %>
                                                        <div
                                                            class="group flex flex-col sm:flex-row sm:items-center justify-between p-6 bg-primary/5 rounded-3xl border border-transparent hover:border-primary/20 hover:bg-white hover:shadow-2xl hover:shadow-primary/5 transition-all">
                                                            <div class="flex items-center gap-6 mb-4 sm:mb-0">
                                                                <div
                                                                    class="w-14 h-14 shrink-0 rounded-2xl <%= typeColor === 'rose' ? 'bg-rose-500/10 text-rose-500' : (typeColor === 'emerald' ? 'bg-emerald-500/10 text-emerald-500' : 'bg-primary/10 text-primary') %> flex items-center justify-center font-black text-xs shadow-sm ring-4 ring-white">
                                                                    <%= fileType %>
                                                                </div>
                                                                <div class="overflow-hidden">
                                                                    <p
                                                                        class="text-base font-black text-secondary group-hover:text-primary transition-colors line-clamp-1">
                                                                        <%= doc.title %>
                                                                    </p>
                                                                    <div class="flex items-center gap-3 mt-1">
                                                                        <span
                                                                            class="text-[9px] font-black uppercase tracking-widest text-primary bg-primary/10 px-2 py-0.5 rounded-full">Secure</span>
                                                                        <span
                                                                            class="text-[10px] font-bold text-slate-400">
                                                                            <%= doc.fileSize %>
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <div class="flex items-center gap-2">
                                                                <button
                                                                    onclick="viewDocument('<%= doc.title %>', '<%= doc.url %>')"
                                                                    class="px-6 py-3.5 bg-white text-secondary border border-slate-100 rounded-xl text-[10px] font-black uppercase tracking-[0.15em] hover:bg-primary hover:text-white hover:border-primary transition-all active:scale-95 shadow-lg shadow-slate-200/50">
                                                                    View
                                                                </button>
                                                                <a href="<%= doc.url %>" download
                                                                    class="p-3.5 bg-primary text-white rounded-xl hover:bg-secondary hover:scale-110 shadow-lg shadow-primary/20 transition-all">
                                                                    <svg class="w-5 h-5" fill="none"
                                                                        stroke="currentColor" viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round"
                                                                            stroke-linejoin="round" stroke-width="2.5"
                                                                            d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                                                                    </svg>
                                                                </a>
                                                            </div>
                                                        </div>
                                                        <% }) %>
                                            </div>
                                        </div>
                                        <% }) %>
                                            <% } else { %>
                                                <div
                                                    class="lg:col-span-2 text-center py-24 bg-white rounded-[4rem] border border-dashed border-slate-200">
                                                    <div
                                                        class="w-20 h-20 bg-slate-50 rounded-3xl flex items-center justify-center mx-auto mb-6">
                                                        <svg class="w-10 h-10 text-slate-300" fill="none"
                                                            stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                                stroke-width="2"
                                                                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                                        </svg>
                                                    </div>
                                                    <p class="text-slate-400 font-bold uppercase tracking-widest">No
                                                        resources assigned to your profile yet.</p>
                                                </div>
                                                <% } %>
                            </div>

                            <!-- Test Reports Section -->
                        </div>
                    </div>

                    <!-- VIDEOS TAB -->
                    <div id="content-videos" class="tab-pane hidden animate-fade-in">
                        <% if (user && user.role==='affiliate' ) { %>
                            <!-- Coming Soon State for Affiliates -->
                            <div
                                class="bg-white rounded-[3rem] p-12 md:p-24 text-center border border-slate-100 shadow-sm relative overflow-hidden group mb-12">
                                <div
                                    class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 to-transparent pointer-events-none">
                                </div>
                                <div
                                    class="w-20 h-20 bg-emerald-50 rounded-[2.2rem] flex items-center justify-center mx-auto mb-10 shadow-inner ring-8 ring-white">
                                    <svg class="w-10 h-10 text-emerald-500 animate-pulse" fill="none"
                                        stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                            d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                                    </svg>
                                </div>
                                <h3
                                    class="text-4xl md:text-5xl font-black text-secondary tracking-tighter mb-4 uppercase italic">
                                    Partner <span class="text-emerald-500">Video Content</span></h3>
                                <p class="text-[10px] font-black text-slate-400 uppercase tracking-[0.3em] mb-10">Coming
                                    Soon to Creator Studio</p>
                                <div class="w-12 h-1.5 bg-emerald-500/20 rounded-full mx-auto mb-10"></div>
                                <p
                                    class="text-slate-500 font-bold uppercase tracking-widest text-sm max-w-xl mx-auto leading-relaxed px-6">
                                    We are currently producing exclusive masterclasses and marketing asset training
                                    videos for our affiliate partners. Check back shortly for premium content.
                                </p>
                            </div>
                            <% } else { %>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                    <% const videos=[ { id: 'BGc7Vll5jQE' , title: 'The Future of Refrigeration' ,
                                        category: 'Overview' , duration: '2:56' }, { id: 'u1ca6RnhqyE' ,
                                        title: 'System Installation Guide' , category: 'Setup' , duration: '1:34' }, {
                                        id: '2Q_cg1GrbMM' , title: 'System Maintenance' , category: 'Maintenance' ,
                                        duration: '1:12' }]; %>
                                        <% videos.forEach(vid=> { %>
                                            <div
                                                class="bg-white rounded-[3rem] overflow-hidden shadow-sm border border-slate-100 group hover:shadow-2xl transition-all duration-500 reveal">
                                                <div class="aspect-video relative overflow-hidden bg-slate-100">
                                                    <img src="https://img.youtube.com/vi/<%= vid.id %>/hqdefault.jpg"
                                                        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                                                    <div
                                                        class="absolute inset-0 bg-slate-900/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                                        <button
                                                            onclick="openVideoModal('<%= vid.id %>', '<%= vid.title %>')"
                                                            class="w-20 h-20 bg-emerald-500 text-white rounded-full flex items-center justify-center shadow-2xl scale-75 group-hover:scale-100 transition-all duration-500">
                                                            <svg class="w-8 h-8 fill-current ml-1" viewBox="0 0 24 24">
                                                                <path d="M8 5v14l11-7z" />
                                                            </svg>
                                                        </button>
                                                    </div>
                                                    <div
                                                        class="absolute bottom-4 right-4 px-3 py-1 bg-black/60 backdrop-blur-md rounded-lg text-white text-[10px] font-black">
                                                        <%= vid.duration %>
                                                    </div>
                                                </div>
                                                <div class="p-10">
                                                    <div class="flex items-center justify-between mb-5">
                                                        <span
                                                            class="text-[10px] font-black text-emerald-600 uppercase tracking-[0.2em] py-1.5 px-3 bg-emerald-50 rounded-lg">
                                                            <%= vid.category %>
                                                        </span>
                                                        <div class="flex gap-1.5 opacity-30">
                                                            <div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div>
                                                            <div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div>
                                                        </div>
                                                    </div>
                                                    <h4
                                                        class="text-2xl font-black text-slate leading-tight group-hover:text-emerald-600 transition-colors">
                                                        <%= vid.title %>
                                                    </h4>
                                                    <p class="text-slate-400 text-sm mt-3 font-medium">Explore the
                                                        impact of
                                                        RD Fresh on <%= vid.category.toLowerCase() %> efficiency.</p>
                                                </div>
                                            </div>
                                            <% }) %>
                                </div>
                                <% } %>
                    </div>

                    <!-- HOW IT WORKS TAB -->
                    <div id="content-how-it-works" class="tab-pane hidden animate-fade-in">
                        <% if (user && user.role==='affiliate' ) { %>
                            <!-- AFFILIATE SPECIFIC "HOW IT WORKS" CONTENT -->
                            <div class="space-y-12">
                                <!-- Hero Section -->
                                <div
                                    class="bg-white rounded-[4rem] p-10 md:p-20 shadow-xl border border-slate-100 reveal relative overflow-hidden group">
                                    <div
                                        class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-emerald-500/5 to-transparent pointer-events-none">
                                    </div>
                                    <div class="relative z-10">
                                        <div class="inline-block px-4 py-1.5 bg-emerald-500/10 rounded-full mb-8">
                                            <p
                                                class="text-[10px] font-black text-emerald-600 tracking-[0.3em] uppercase">
                                                Revenue Transformation</p>
                                        </div>
                                        <h2
                                            class="text-4xl md:text-7xl font-black text-secondary tracking-tighter mb-8 uppercase leading-[0.9]">
                                            Turn Your Walk-In Cooler Technology<br><span
                                                class="text-emerald-500 italic">into a New
                                                Revenue Stream.</span>
                                        </h2>
                                        <p
                                            class="text-slate-500 font-bold uppercase tracking-widest text-lg max-w-3xl leading-relaxed">
                                            What if the same technology you rely on in your walk-in coolers could
                                            generate a new quarterly revenue stream while showing your customers you
                                            care about their health, their wallets, and the planet?
                                        </p>
                                    </div>
                                </div>

                                <!-- The Problem & Statistics -->
                                <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
                                    <div
                                        class="lg:col-span-12 bg-slate-900 rounded-[3rem] p-10 md:p-16 text-white relative overflow-hidden shadow-2xl">
                                        <div
                                            class="absolute top-0 right-0 w-full h-full bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')] opacity-10">
                                        </div>
                                        <div class="relative z-10 flex flex-col md:flex-row items-center gap-12">
                                            <div class="shrink-0">
                                                <div
                                                    class="w-32 h-32 bg-white/10 backdrop-blur-xl rounded-full flex items-center justify-center border border-white/20">
                                                    <span
                                                        class="text-5xl font-black text-emerald-400 font-mono">$2.9k</span>
                                                </div>
                                            </div>
                                            <div>
                                                <h4 class="text-2xl font-black uppercase tracking-tighter mb-4 italic">
                                                    The $2,900 Opportunity</h4>
                                                <p class="text-slate-400 font-medium text-lg leading-relaxed">
                                                    The average family of four throws away approximately <span
                                                        class="text-white">$2,900 worth of spoiled food every
                                                        year</span>—and produce makes up the majority of that waste.
                                                    Your customers are tired of seeing their money go into the trash,
                                                    and right now, you are leaving that potential revenue on the table.
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Meet VeggieFresh -->
                                <div
                                    class="bg-white rounded-[3rem] p-10 md:p-16 border border-slate-100 shadow-sm reveal">
                                    <div class="flex flex-col md:flex-row items-start gap-12">
                                        <div class="md:w-1/2">
                                            <h3
                                                class="text-3xl font-black text-secondary mb-8 uppercase italic tracking-tighter flex items-center gap-4">
                                                <div
                                                    class="w-10 h-10 rounded-xl bg-emerald-500 text-white flex items-center justify-center shadow-lg shadow-emerald-500/20 text-xs">
                                                    VF</div>
                                                Meet VeggieFresh
                                            </h3>
                                            <p class="text-slate-500 font-bold text-lg leading-relaxed mb-8">
                                                VeggieFresh is the home version of the exact RD FRESH technology you
                                                already use in your restaurant's walk-in cooler to keep produce fresher
                                                for longer.
                                            </p>
                                            <div class="space-y-6">
                                                <div
                                                    class="flex items-center gap-5 p-6 bg-slate-50 rounded-2xl border border-slate-100 hover:border-emerald-500/30 transition-all group">
                                                    <div
                                                        class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center text-emerald-500 group-hover:scale-110 transition-transform">
                                                        <svg class="w-6 h-6" fill="none" stroke="currentColor"
                                                            viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                                stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
                                                        </svg>
                                                    </div>
                                                    <div>
                                                        <p
                                                            class="text-primary font-black uppercase text-sm tracking-widest mb-1">
                                                            Simple to Use</p>
                                                        <p class="text-primary text-xs font-bold uppercase">It is a
                                                            small mineral pack that customers simply drop into their
                                                            refrigerator drawer.</p>
                                                    </div>
                                                </div>
                                                <div
                                                    class="flex items-center gap-5 p-6 bg-slate-50 rounded-2xl border border-slate-100 hover:border-emerald-500/30 transition-all group">
                                                    <div
                                                        class="w-12 h-12 bg-white rounded-xl shadow-sm flex items-center justify-center text-emerald-500 group-hover:scale-110 transition-transform">
                                                        <svg class="w-6 h-6" fill="none" stroke="currentColor"
                                                            viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round"
                                                                stroke-width="2.5"
                                                                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                        </svg>
                                                    </div>
                                                    <div>
                                                        <p
                                                            class="text-primary font-black uppercase text-sm tracking-widest mb-1">
                                                            Scientifically Effective</p>
                                                        <p class="text-primary text-xs font-bold uppercase">The
                                                            minerals absorb ethylene gas—the natural culprit behind food
                                                            spoilage— keeping produce fresh up to 50% longer</p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div
                                            class="md:w-1/2 bg-slate-50 rounded-[4rem] p-8 border border-slate-100 relative h-full">
                                            <div
                                                class="aspect-square bg-white rounded-[3rem] shadow-xl flex items-center justify-center border border-slate-100 relative overflow-hidden group">
                                                <div
                                                    class="absolute inset-0 bg-emerald-500/5 opacity-0 group-hover:opacity-100 transition-opacity">
                                                </div>
                                                <img src="/images/vegie_work.png" alt="VeggieFresh System"
