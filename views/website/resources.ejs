                <!-- Mammoth.js for DOCX preview on local -->
                <script src="https://cdnjs.cloudflare.com/ajax/libs/mammoth/1.6.0/mammoth.browser.min.js"></script>

                <style>
                    .paper-wrapper {
                        max-width: 850px;
                        margin: 0 auto;
                        background: #0f172a;
                        /* bg-slate-900 */
                        padding: 4rem;
                        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
                        border-radius: 4px;
                        min-height: 100%;
                        border: 1px solid rgba(255, 255, 255, 0.05);
                    }

                    /* Tabs Styling */
                    .tab-pane {
                        transition: opacity 0.3s ease-in-out;
                    }

                    .tab-pane.hidden {
                        display: none;
                    }

                    /* Premium Document Typography for Dark Mode */
                    .doc-content h1 {
                        font-size: 2.25rem;
                        font-weight: 900;
                        color: #ffffff;
                        margin-bottom: 2rem;
                        border-bottom: 2px solid rgba(255, 255, 255, 0.05);
                        padding-bottom: 1rem;
                    }

                    .doc-content h2 {
                        font-size: 1.5rem;
                        font-weight: 800;
                        color: #f1f5f9;
                        margin-top: 2rem;
                        margin-bottom: 1rem;
                    }

                    .doc-content h3 {
                        font-size: 1.25rem;
                        font-weight: 700;
                        color: #e2e8f0;
                        margin-top: 1.5rem;
                        margin-bottom: 0.75rem;
                    }

                    .doc-content p {
                        font-size: 1.125rem;
                        line-height: 1.8;
                        color: #94a3b8;
                        margin-bottom: 1.25rem;
                    }

                    .doc-content ul,
                    .doc-content ol {
                        margin-left: 1.5rem;
                        margin-bottom: 1.5rem;
                        color: #94a3b8;
                    }

                    .doc-content li {
                        margin-bottom: 0.5rem;
                        font-size: 1.125rem;
                        line-height: 1.6;
                    }

                    .doc-content table {
                        width: 100%;
                        border-collapse: collapse;
                        margin-bottom: 2rem;
                    }

                    .doc-content td,
                    .doc-content th {
                        border: 1px solid rgba(255, 255, 255, 0.1);
                        padding: 0.75rem;
                        text-align: left;
                        color: #cbd5e1;
                    }

                    /* Tabs Styling */
                    .tab-pane {
                        transition: opacity 0.3s ease-in-out;
                    }

                    .tab-pane.hidden {
                        display: none;
                    }

                    .tab-btn.active {
                        background-color: #10b981;
                        color: white !important;
                        border-color: #10b981;
                        box-shadow: 0 10px 30px rgba(16, 185, 129, 0.2);
                    }

                    @keyframes fade-in {
                        from {
                            opacity: 0;
                            transform: translateY(10px);
                        }

                        to {
                            opacity: 1;
                            transform: translateY(0);
                        }
                    }

                    @keyframes float {

                        0%,
                        100% {
                            transform: translateY(0) scale(1);
                        }

                        50% {
                            transform: translateY(-20px) scale(1.05);
                        }
                    }

                    @keyframes float-delayed {

                        0%,
                        100% {
                            transform: translateY(0) rotate(0);
                        }

                        50% {
                            transform: translateY(20px) rotate(5deg);
                        }
                    }

                    .animate-float {
                        animation: float 8s ease-in-out infinite;
                    }

                    .animate-float-delayed {
                        animation: float-delayed 12s ease-in-out infinite;
                    }

                    .animate-fade-in {
                        animation: fade-in 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
                    }
                </style>

                <script>
                    function switchTab(tabName) {
                        const panes = document.querySelectorAll('.tab-pane');
                        const buttons = document.querySelectorAll('.tab-btn');

                        panes.forEach(p => { p.classList.add('hidden'); p.classList.remove('active'); });
                        buttons.forEach(b => {
                            b.classList.remove('active');
                            b.classList.add('text-slate-500');
                        });

                        const activePane = document.getElementById('content-' + tabName);
                        activePane.classList.remove('hidden');
                        activePane.classList.add('active');

                        const activeBtn = document.getElementById('tab-' + tabName);
                        activeBtn.classList.add('active');
                        activeBtn.classList.remove('text-primary');

                        if (typeof reveal === 'function') setTimeout(reveal, 100);
                    }

                    function openVideoModal(youtubeId, title) {
                        const modal = document.getElementById('videoModal');
                        const iframe = document.getElementById('videoIframe');
                        const loader = document.getElementById('videoLoading');

                        loader.classList.remove('hidden', 'opacity-0');
                        iframe.src = `https://www.youtube.com/embed/${youtubeId}?autoplay=1&rel=0&modestbranding=1`;

                        modal.classList.remove('hidden');
                        modal.classList.add('flex');
                        document.body.style.overflow = 'hidden';
                    }

                    function closeVideoModal() {
                        const modal = document.getElementById('videoModal');
                        const iframe = document.getElementById('videoIframe');
                        iframe.src = "";
                        modal.classList.add('hidden');
                        modal.classList.remove('flex');
                        document.body.style.overflow = '';
                    }

                    async function viewDocument(name, path) {
                        const modal = document.getElementById('docViewerModal');
                        const iframe = document.getElementById('docIframe');
                        const title = document.getElementById('modalFileTitle');
                        const downloadBtn = document.getElementById('modalDownloadBtn');
                        const loader = document.getElementById('viewerLoading');

                        let previewContainer = document.getElementById('docxPreview');
                        if (!previewContainer) {
                            previewContainer = document.createElement('div');
                            previewContainer.id = 'docxPreview';
                            previewContainer.className = 'absolute inset-0 overflow-y-auto bg-slate-950 hidden z-0 py-12';
                            iframe.parentElement.appendChild(previewContainer);
                        }

                        loader.classList.remove('hidden');
                        loader.style.opacity = '1';
                        iframe.classList.add('hidden');
                        previewContainer.classList.add('hidden');
                        previewContainer.innerHTML = "";
                        iframe.src = "";

                        title.innerText = name;
                        downloadBtn.href = path;

                        const isLocalhost = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
                        // Robust extension check
                        const ext = path.split(/[#?]/)[0].split('.').pop().trim().toLowerCase();
                        const isDoc = ext === 'docx' || ext === 'doc';
                        const isRemote = path.startsWith('http');

                        // Use Mammoth for local DOCX files on localhost, otherwise Google Viewer for remote
                        if (isDoc && !isRemote && isLocalhost) {
                            try {
                                const response = await fetch(path);
                                const arrayBuffer = await response.arrayBuffer();
                                const result = await mammoth.convertToHtml({ arrayBuffer: arrayBuffer });
                                previewContainer.innerHTML = `<div class="paper-wrapper doc-content shadow-2xl my-12">${result.value}</div><div class="h-24"></div>`;
                                previewContainer.classList.remove('hidden');
                                setTimeout(() => {
                                    loader.style.opacity = '0';
                                    setTimeout(() => loader.classList.add('hidden'), 300);
                                }, 100);
                            } catch (error) {
                                console.error("Mammoth Error:", error);
                                iframe.src = path;
                                iframe.classList.remove('hidden');
                            }
                        } else {
                            let viewerUrl = path;
                            if (isDoc) {
                                // Google Viewer requires full absolute URL
                                const fullUrl = isRemote ? path : window.location.origin + path;
                                viewerUrl = `https://docs.google.com/viewer?url=${encodeURIComponent(fullUrl)}&embedded=true`;
                            }
                            iframe.src = viewerUrl;
                            iframe.classList.remove('hidden');
                        }

                        modal.classList.remove('hidden');
                        modal.classList.add('flex');
                        document.body.style.overflow = 'hidden';
                    }

                    function closeDocViewer() {
                        const modal = document.getElementById('docViewerModal');
                        const iframe = document.getElementById('docIframe');
                        const previewContainer = document.getElementById('docxPreview');
                        const loader = document.getElementById('viewerLoading');

                        iframe.src = "";
                        if (previewContainer) {
                            previewContainer.innerHTML = "";
                            previewContainer.classList.add('hidden');
                        }
                        modal.classList.add('hidden');
                        modal.classList.remove('flex');
                        loader.classList.add('hidden');
                        document.body.style.overflow = '';
                    }

                    document.addEventListener('keydown', (e) => {
                        if (e.key === 'Escape') closeDocViewer();
                    });
                </script>
    </body>

