<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>

    <body class="bg-white text-secondary overflow-x-hidden selection:bg-primary/30">

        <%- include('partials/header') %>

            <!-- Decorative Background Elements -->
            <div class="fixed inset-0 pointer-events-none -z-10 overflow-hidden">
                <div
                    class="absolute -top-[10%] -right-[10%] w-[400px] h-[400px] bg-primary/5 rounded-full blur-[120px] animate-pulse">
                </div>
                <div class="absolute top-[20%] -left-[10%] w-[300px] h-[300px] bg-primary/5 rounded-full blur-[100px]">
                </div>
            </div>

            <main class="pt-40 pb-24 relative">
                <section class="container mx-auto px-6 max-w-7xl">
                    <!-- Back Button -->
                    <div class="mb-12 reveal">
                        <a href="/shop"
                            class="inline-flex items-center gap-3 text-slate-400 font-black text-[10px] uppercase tracking-[0.3em] hover:text-primary transition-all duration-300 group">
                            <div
                                class="w-10 h-10 rounded-full bg-primary flex items-center justify-center group-hover:bg-primary/10 transition-colors">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                                </svg>
                            </div>
                            Back to Products
                        </a>
                    </div>

                    <div
                        class="bg-white rounded-[4rem] overflow-hidden shadow-2xl border border-slate-100 flex flex-col lg:flex-row min-h-[600px] reveal">
                        <!-- Image Side -->
                        <div class="lg:w-1/2 bg-primary relative overflow-hidden group">
                            <img src="<%= product.imageUrl || 'https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&fit=crop&q=80&w=800' %>"
                                alt="<%= product.name %>"
                                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105">
                            <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-40">
                            </div>
                        </div>

                        <!-- Details Side -->
                        <div class="lg:w-1/2 p-10 md:p-16 lg:p-20 flex flex-col justify-center">
                            <div class="mb-10">
                                <div class="inline-block px-4 py-1.5 bg-primary/10 rounded-full mb-6">
                                    <p class="text-[10px] font-black text-primary tracking-[0.3em] uppercase">
                                        SKU: <%= product.sku %>
                                    </p>
                                </div>
                                <h1
                                    class="text-4xl md:text-6xl font-black text-secondary leading-[0.9] mb-8 uppercase tracking-tighter">
                                    <%= product.name %>
                                </h1>
                                <div class="flex items-baseline gap-4 mb-8">
                                    <p class="text-4xl font-black text-primary tracking-tighter">
                                        $<%= parseFloat(product.price || 0).toFixed(2) %>
                                    </p>
                                    <p class="text-slate-300 font-bold uppercase text-xs tracking-widest italic">
                                        Professional Grade</p>
                                </div>
                            </div>

                            <div class="space-y-10">
                                <div>
                                    <h4
                                        class="text-[10px] font-black text-slate-400 uppercase tracking-[0.4em] mb-6 border-b border-slate-100 pb-3">
                                        Technical Specifications</h4>
                                    <p class="text-slate-500 font-medium text-xl leading-relaxed">
                                        <%= product.description
                                            || 'High-performance refrigeration solution designed for professional commercial storage environments. Engineered for maximum atmosphere control and produce longevity.'
                                            %>
                                    </p>
                                </div>

                                <div class="pt-6">
                                    <button
                                        class="add-to-cart-btn w-full py-6 bg-secondary text-white font-black text-[12px] uppercase tracking-[0.3em] rounded-2xl hover:bg-primary hover:shadow-2xl hover:shadow-primary/30 transition-all duration-500 transform hover:-translate-y-1"
                                        data-id="<%= product.productId %>" data-name="<%= product.name %>"
                                        data-price="<%= product.price || 0 %>"
                                        data-image="<%= product.imageUrl || 'https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&fit=crop&q=80&w=800' %>">
                                        Add to Cart
                                    </button>

                                    <div
                                        class="mt-8 flex items-center justify-center gap-8 border-t border-slate-50 pt-8">
                                        <div class="flex flex-col items-center">
                                            <div
                                                class="w-10 h-10 bg-primary rounded-full flex items-center justify-center mb-2">
                                                <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path d="M5 13l4 4L19 7" stroke-width="2.5" stroke-linecap="round"
                                                        stroke-linejoin="round"></path>
                                                </svg>
                                            </div>
                                            <span
                                                class="text-[8px] font-black uppercase tracking-widest text-slate-400">In
                                                Stock</span>
                                        </div>
                                        <div class="flex flex-col items-center">
                                            <div
                                                class="w-10 h-10 bg-primary rounded-full flex items-center justify-center mb-2">
                                                <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                                        stroke-width="2.5" stroke-linecap="round"
                                                        stroke-linejoin="round"></path>
                                                </svg>
                                            </div>
                                            <span
                                                class="text-[8px] font-black uppercase tracking-widest text-slate-400">Fast
                                                Shipping</span>
                                        </div>
                                        <div class="flex flex-col items-center">
                                            <div
                                                class="w-10 h-10 bg-primary rounded-full flex items-center justify-center mb-2">
                                                <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path
                                                        d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                                                        stroke-width="2.5" stroke-linecap="round"
                                                        stroke-linejoin="round"></path>
                                                </svg>
                                            </div>
                                            <span
                                                class="text-[8px] font-black uppercase tracking-widest text-slate-400">Secured</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </main>

            <%- include('partials/footer') %>

                <style>
                    @keyframes slide-in {
                        from {
                            transform: translateX(400px);
                            opacity: 0;
                        }

                        to {
                            transform: translateX(0);
                            opacity: 1;
                        }
                    }

                    .animate-slide-in {
                        animation: slide-in 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
                    }

                    .reveal {
                        opacity: 0;
                        transform: translateY(20px);
                        transition: all 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
                    }

                    .reveal.active {
                        opacity: 1;
                        transform: translateY(0);
                    }
                </style>

                <script>
                    // Reveal logic
                    function reveal() {
                        document.querySelectorAll(".reveal").forEach(el => {
                            const windowHeight = window.innerHeight;
                            const elementTop = el.getBoundingClientRect().top;
                            if (elementTop < windowHeight - 100) el.classList.add("active");
                        });
                    }
                    window.addEventListener("scroll", reveal);
                    window.addEventListener("load", reveal);

                    // Add to Cart Logic
                    document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
                        btn.addEventListener('click', async () => {
                        <% if (!user) { %>
                                window.location.href = '/login';
                                return;
                        <% } %>

                        const productId = btn.getAttribute('data-id');
                            const productName = btn.getAttribute('data-name');
                            const price = btn.getAttribute('data-price');
                            const image = btn.getAttribute('data-image');

                            try {
                                const response = await fetch('/cart/add', {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify({ productId, productName, price, image, quantity: 1 })
                                });

                                const data = await response.json();

                                if (data.success) {
                                    const toast = document.createElement('div');
                                    toast.className = 'fixed top-24 right-6 bg-blue-600 text-white px-8 py-5 rounded-[2rem] shadow-2xl z-50 flex items-center gap-4 animate-slide-in border border-white/10 backdrop-blur-xl';
                                    toast.innerHTML = `
                                    <div class="w-10 h-10 rounded-xl bg-white/20 flex items-center justify-center shrink-0">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="font-black text-sm uppercase tracking-wider">${productName}</p>
                                        <p class="text-xs font-bold text-blue-100/80">Inventory updated. Heading to cart...</p>
                                    </div>
                                `;
                                    document.body.appendChild(toast);
                                    setTimeout(() => { window.location.href = '/cart'; }, 1500);
                                } else {
                                    alert(data.message || 'Error adding to cart');
                                }
                            } catch (error) {
                                console.error('Error:', error);
                                alert('Error adding to cart. Please try again.');
                            }
                        });
                    });
                </script>
    </body>

</html>