<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>

    <body class="bg-slate-950 text-slate-50 overflow-x-hidden">
        <%- include('partials/header') %>

            <main
                class="min-h-screen flex items-center justify-center py-24 md:py-32 px-6 relative overflow-hidden hero-gradient">
                <!-- Background Ornaments -->
                <div class="absolute top-0 left-0 w-full h-full pointer-events-none -z-10">
                    <div
                        class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-emerald-100/40 rounded-full blur-[120px] animate-pulse">
                    </div>
                    <div
                        class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-blue-100/30 rounded-full blur-[120px]">
                    </div>
                </div>

                <div
                    class="w-full max-w-5xl grid grid-cols-1 lg:grid-cols-2 bg-slate-900 border border-white/5 rounded-[2.5rem] md:rounded-[3.5rem] shadow-[0_50px_100px_-20px_rgba(0,0,0,0.5)] overflow-hidden animate-fade-in-up mx-auto relative z-10">
                    <!-- Left Side: Value & Social Proof -->
                    <div
                        class="hidden lg:flex flex-col justify-between p-12 xl:p-16 bg-slate-900 text-white relative overflow-hidden">
                        <!-- Decorative Pattern -->
                        <div class="absolute inset-0 opacity-10"
                            style="background-image: url('data:image/svg+xml,%3Csvg width=%2260%22 height=%2260%22 viewBox=%220 0 60 60%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cg fill=%22none%22 fill-rule=%22evenodd%22%3E%3Cg fill=%22%23ffffff%22 fill-opacity=%220.4%22%3E%3Cpath d=%22M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');">
                        </div>


                        <div class="relative z-10">
                            <a href="/" class="inline-block mb-12 group">
                                <img src="/images/new-logo.png" alt="RD Fresh"
                                    class="h-10 w-auto brightness-200 group-hover:scale-105 transition-transform">
                            </a>
                            <div class="space-y-6">
                                <h2 class="text-4xl xl:text-5xl font-black tracking-tight leading-[1.1] text-white">
                                    Welcome back to <br> <span class="text-blue-400">RD Fresh.</span>
                                </h2>
                                <p class="text-slate-400 text-lg leading-relaxed max-w-sm font-medium">
                                    Login to access your personalized sustainability metrics and manage your
                                    inventory protection systems.
                                </p>
                            </div>
                        </div>

                        <div class="relative z-10 space-y-8">
                            <!-- Feature Highlight -->
                            <div class="space-y-5">
                                <div class="flex items-center gap-4 group">
                                    <div
                                        class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center text-blue-400 group-hover:bg-blue-600 group-hover:text-white transition-all">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                                d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                                        </svg>
                                    </div>
                                    <p class="text-sm font-bold text-slate-200">View real-time ROI & Savings</p>
                                </div>
                                <div class="flex items-center gap-4 group">
                                    <div
                                        class="w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center text-blue-400 group-hover:bg-blue-600 group-hover:text-white transition-all">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                                        </svg>
                                    </div>
                                    <p class="text-sm font-bold text-slate-200">NSF Certified Safety Standards</p>
                                </div>
                            </div>

                            <div class="pt-8 border-t border-white/10">
                                <div class="flex items-center gap-4">
                                    <div class="flex -space-x-3">
                                        <img class="w-10 h-10 rounded-full border-2 border-slate-900 shadow-lg"
                                            src="https://ui-avatars.com/api/?name=J&background=10B981&color=fff" alt="">
                                        <img class="w-10 h-10 rounded-full border-2 border-slate-900 shadow-lg"
                                            src="https://ui-avatars.com/api/?name=M&background=0F172A&color=fff" alt="">
                                        <img class="w-10 h-10 rounded-full border-2 border-slate-900 shadow-lg"
                                            src="https://ui-avatars.com/api/?name=S&background=3B82F6&color=fff" alt="">
                                    </div>
                                    <p
                                        class="text-[10px] font-black text-slate-500 uppercase tracking-widest leading-tight">
                                        Trusted by managers at <br><span class="text-white">500+ Top Facilities</span>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <!-- Gradient Glow -->
                        <div class="absolute -bottom-20 -right-20 w-80 h-80 bg-blue-500/10 rounded-full blur-[100px]">
                        </div>
                    </div>

                    <!-- Right Side: Login Form -->
                    <div class="p-6 sm:p-10 md:p-16 lg:p-20 flex flex-col justify-center relative">
                        <div class="space-y-8">
                            <!-- Role Switcher Tabs -->
                            <div
                                class="flex p-1 bg-white/5 rounded-2xl mb-2 border border-white/10 max-w-md mx-auto lg:mx-0">
                                <button type="button" id="customerTab" onclick="switchTab('customer')"
                                    class="flex-1 py-3 text-[9px] font-black uppercase tracking-widest rounded-xl transition-all bg-blue-600 text-white shadow-lg shadow-blue-600/20">
                                    Customer
                                </button>
                                <button type="button" id="distributorTab" onclick="switchTab('distributor')"
                                    class="flex-1 py-3 text-[9px] font-black uppercase tracking-widest rounded-xl transition-all text-slate-500 hover:text-white">
                                    Distributor
                                </button>
                                <button type="button" id="affiliateTab" onclick="switchTab('affiliate')"
                                    class="flex-1 py-3 text-[9px] font-black uppercase tracking-widest rounded-xl transition-all text-slate-500 hover:text-white">
                                    Affiliate
                                </button>
                            </div>

                            <div class="text-center lg:text-left">
                                <h3 id="formTitle" class="text-3xl font-black text-white tracking-tight mb-2">Customer
                                    Login</h3>
                                <p id="formSubtext" class="text-slate-400 font-medium tracking-tight">Access your
                                    facility's protection dashboard.</p>
                            </div>

                            <% if (success_msg && success_msg.length> 0) { %>
                                <div
                                    class="p-4 bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 rounded-2xl text-sm font-bold animate-fade-in-up uppercase tracking-widest text-[11px] text-center">
                                    <%= success_msg %>
                                </div>
                                <% } %>

                                    <% if (error_msg && error_msg.length> 0) { %>
                                        <div
                                            class="p-4 bg-rose-500/10 border border-rose-500/20 text-rose-400 rounded-2xl text-sm font-bold animate-fade-in-up uppercase tracking-widest text-[11px] text-center">
                                            <%= error_msg %>
                                        </div>
                                        <% } %>

                                            <form id="loginForm" action="/login" method="POST" class="space-y-6">
                                                <div class="space-y-2">
                                                    <label id="emailLabel"
                                                        class="text-[11px] font-black text-slate-400 uppercase tracking-widest">Email
                                                        Address</label>
                                                    <input type="email" name="email" required
                                                        placeholder="name@company.com"
                                                        class="w-full bg-white/5 border-2 border-white/5 focus:border-blue-600 focus:bg-white/10 rounded-2xl px-6 py-4 outline-none transition-all font-bold text-white placeholder-slate-500">
                                                </div>
                                                <div class="space-y-2">
                                                    <div class="flex justify-between items-center">
                                                        <label
                                                            class="text-[11px] font-black text-slate-400 uppercase tracking-widest">Password</label>
                                                        <a href="#" id="forgotLink"
                                                            class="text-[10px] font-black text-blue-400 uppercase tracking-widest hover:underline">Forgot
                                                            Password?</a>
                                                    </div>
                                                    <input type="password" name="password" required
                                                        placeholder="••••••••"
                                                        class="w-full bg-white/5 border-2 border-white/5 focus:border-blue-600 focus:bg-white/10 rounded-2xl px-6 py-4 outline-none transition-all font-bold text-white placeholder-slate-500">
                                                </div>

                                                <div class="flex items-center gap-3">
                                                    <input type="checkbox" id="remember"
                                                        class="w-5 h-5 rounded-lg border-white/10 bg-slate-800 text-blue-600 focus:ring-blue-500 transition-all cursor-pointer">
                                                    <label for="remember"
                                                        class="text-sm font-bold text-slate-500 cursor-pointer">Keep me
                                                        logged in</label>
                                                </div>

                                                <button type="submit" id="submitBtn"
                                                    class="w-full py-5 bg-blue-600 text-white font-black uppercase tracking-[0.2em] text-xs rounded-2xl hover:bg-blue-500 transition-all shadow-xl shadow-blue-500/20 active:scale-[0.98] flex items-center justify-center gap-3">
                                                    <span id="submitBtnText">Enter Fresh Portal</span>
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor"
                                                        viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                                    </svg>
                                                </button>
                                            </form>

                                            <div class="text-center pt-8 border-t border-white/5">
                                                <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">
                                                    <span id="footerText">New facility?</span>
                                                    <a href="/signup" id="footerLink"
                                                        class="text-blue-400 hover:underline">Create an account</a>
                                                </p>
                                            </div>
                        </div>
                    </div>
                </div>
            </main>

            <script>
                function switchTab(role) {
                    console.log('Switching to role:', role);
                    const elements = {
                        customerTab: document.getElementById('customerTab'),
                        distributorTab: document.getElementById('distributorTab'),
                        affiliateTab: document.getElementById('affiliateTab'),
                        formTitle: document.getElementById('formTitle'),
                        formSubtext: document.getElementById('formSubtext'),
                        loginForm: document.getElementById('loginForm'),
                        submitBtn: document.getElementById('submitBtn'),
                        submitBtnText: document.getElementById('submitBtnText'),
                        footerText: document.getElementById('footerText'),
                        footerLink: document.getElementById('footerLink'),
                        emailLabel: document.getElementById('emailLabel'),
                        forgotLink: document.getElementById('forgotLink')
                    };

                    // Basic verification
                    if (!elements.customerTab || !elements.distributorTab || !elements.loginForm) {
                        console.error('Required elements not found');
                        return;
                    }

                    // Reset all tabs
                    [elements.customerTab, elements.distributorTab, elements.affiliateTab].forEach(tab => {
                        if (tab) {
                            tab.className = "flex-1 py-3 text-[9px] font-black uppercase tracking-widest rounded-xl transition-all text-slate-500 hover:text-white";
                        }
                    });

                    const activeClass = "flex-1 py-3 text-[9px] font-black uppercase tracking-widest rounded-xl transition-all bg-blue-600 text-white shadow-lg shadow-blue-600/20";
                    const affiliateActiveClass = "flex-1 py-3 text-[9px] font-black uppercase tracking-widest rounded-xl transition-all bg-emerald-600 text-white shadow-lg shadow-emerald-600/20";

                    if (role === 'customer') {
                        if (elements.customerTab) elements.customerTab.className = activeClass;
                        if (elements.formTitle) elements.formTitle.textContent = 'Customer Login';
                        if (elements.formSubtext) elements.formSubtext.textContent = "Access your facility's protection dashboard.";
                        elements.loginForm.action = '/login';

                        if (elements.submitBtn) {
                            elements.submitBtn.className = elements.submitBtn.className
                                .replace(/bg-emerald-600|bg-emerald-500/g, 'bg-blue-600')
                                .replace(/shadow-emerald-500/g, 'shadow-blue-500');
                        }
                        if (elements.submitBtnText) elements.submitBtnText.textContent = 'Enter Fresh Portal';
                        if (elements.footerText) elements.footerText.textContent = 'New facility?';
                        if (elements.footerLink) {
                            elements.footerLink.textContent = 'Create an account';
                            elements.footerLink.href = '/signup';
                        }
                        if (elements.emailLabel) elements.emailLabel.textContent = 'Email Address';

                    } else if (role === 'distributor') {
                        if (elements.distributorTab) elements.distributorTab.className = activeClass;
                        if (elements.formTitle) elements.formTitle.textContent = 'Partner Login';
                        if (elements.formSubtext) elements.formSubtext.textContent = 'Credential verification required for network access.';
                        elements.loginForm.action = '/distributor/login';

                        if (elements.submitBtn) {
                            elements.submitBtn.className = elements.submitBtn.className
                                .replace(/bg-emerald-600|bg-emerald-500/g, 'bg-blue-600')
                                .replace(/shadow-emerald-500/g, 'shadow-blue-500');
                        }
                        if (elements.submitBtnText) elements.submitBtnText.textContent = 'Authenticate Access';
                        if (elements.footerText) elements.footerText.textContent = 'Not a partner yet?';
                        if (elements.footerLink) {
                            elements.footerLink.textContent = 'Submit Inquiry';
                            elements.footerLink.href = '/distributor-inquiry';
                        }
                        if (elements.emailLabel) elements.emailLabel.textContent = 'Business Email';

                    } else if (role === 'affiliate') {
                        if (elements.affiliateTab) elements.affiliateTab.className = affiliateActiveClass;
                        if (elements.formTitle) elements.formTitle.textContent = 'Affiliate Login';
                        if (elements.formSubtext) elements.formSubtext.textContent = 'Connect with your audience and track your impact.';
                        elements.loginForm.action = '/affiliate/login';

                        if (elements.submitBtn) {
                            elements.submitBtn.className = elements.submitBtn.className
                                .replace(/bg-blue-600|bg-blue-500/g, 'bg-emerald-600')
                                .replace(/shadow-blue-500/g, 'shadow-emerald-600');
                        }
                        if (elements.submitBtnText) elements.submitBtnText.textContent = 'Access Creator Studio';
                        if (elements.footerText) elements.footerText.textContent = 'Join the network?';
                        if (elements.footerLink) {
                            elements.footerLink.textContent = 'Apply Now';
                            elements.footerLink.href = '/affiliate-inquiry';
                        }
                        if (elements.emailLabel) elements.emailLabel.textContent = 'Affiliate Email';
                    }
                }

                // Handle tab from URL query parameter
                document.addEventListener('DOMContentLoaded', () => {
                    const params = new URLSearchParams(window.location.search);
                    const tab = params.get('tab');
                    if (tab === 'distributor') {
                        switchTab('distributor');
                    } else if (tab === 'affiliate') {
                        switchTab('affiliate');
                    }
                });
            </script>

            <%- include('partials/footer') %>
    </body>

</html>