<!DOCTYPE html>
<html lang="en">
<%- include('partials/head') %>

    <body class="bg-slate-950 text-white overflow-x-hidden selection:bg-blue-100 selection:text-blue-900">
        <%- include('partials/header') %>

            <!-- Decorative Background Elements -->
            <div class="fixed inset-0 pointer-events-none -z-10 overflow-hidden">
                <div
                    class="absolute -top-[10%] -right-[10%] w-[40%] h-[40%] bg-blue-500/10 rounded-full blur-[120px] animate-pulse">
                </div>
                <div class="absolute top-[20%] -left-[10%] w-[30%] h-[30%] bg-blue-500/5 rounded-full blur-[100px]">
                </div>
            </div>

            <main class="min-h-screen pt-32 pb-24 relative">
                <div class="container mx-auto px-4 sm:px-6 max-w-5xl">
                    <!-- Header Section -->
                    <div class="mb-16 flex flex-col md:flex-row md:items-end justify-between gap-8 animate-fade-in">
                        <div class="max-w-2xl">
                            <div
                                class="inline-flex items-center gap-2 px-3 py-1 bg-blue-500/10 text-blue-400 rounded-full text-[10px] font-black uppercase tracking-[0.2em] mb-4 border border-blue-500/10">
                                <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span>
                                Order Management
                            </div>
                            <h1 class="text-5xl sm:text-6xl md:text-7xl font-black text-white tracking-tight mb-6">
                                My <span
                                    class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-blue-600">Orders</span>
                            </h1>
                            <p class="text-slate-400 font-medium text-lg leading-relaxed">
                                Track your shipments, view invoices, and manage your fresh produce history with ease.
                            </p>
                        </div>
                        <div class="flex items-center gap-4">
                            <div
                                class="bg-slate-900 px-6 py-4 rounded-3xl border border-white/5 shadow-2xl text-center min-w-[140px]">
                                <p class="text-[10px] font-black text-slate-500 uppercase tracking-widest mb-1">Total
                                    Orders</p>
                                <p class="text-3xl font-black text-white">
                                    <%= orders ? orders.length : 0 %>
                                </p>
                            </div>
                        </div>
                    </div>

                    <% if (orders && orders.length> 0) { %>
                        <div class="grid grid-cols-1 gap-8">
                            <% orders.forEach((order, index)=> { %>
                                <div class="order-card group bg-slate-900 rounded-[2.5rem] p-4 sm:p-2 border border-white/5 shadow-2xl hover:shadow-blue-500/5 transition-all duration-700 hover:-translate-y-1 relative overflow-hidden"
                                    style="animation: fadeUp 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; animation-delay: <%= index * 0.1 %>s; opacity: 0;">

                                    <!-- Internal Padding Wrapper -->
                                    <div class="p-6 sm:p-8 flex flex-col gap-8">
                                        <!-- Top Row: Status & Type -->
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center gap-4">
                                                <div
                                                    class="w-12 h-12 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-500 group-hover:bg-blue-600 group-hover:text-white transition-all duration-500">
                                                    <svg class="w-6 h-6" fill="none" stroke="currentColor"
                                                        viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            stroke-width="2"
                                                            d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                                                    </svg>
                                                </div>
                                                <div>
                                                    <p
                                                        class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em] mb-0.5">
                                                        Order ID</p>
                                                    <h3 class="text-lg font-black text-white">#<%= order.orderNumber ||
                                                            order.id.toString().slice(-6).toUpperCase() %>
                                                    </h3>
                                                </div>
                                            </div>

                                            <% let statusConfig={ class: "bg-white/5 text-slate-400 border-white/5" ,
                                                icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" }; if
                                                (order.status==='awaiting_shipment' ) { statusConfig={
                                                class: "bg-amber-500/10 text-amber-500 border-amber-500/20" ,
                                                icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" }; } else if
                                                (order.status==='shipped' ) { statusConfig={
                                                class: "bg-blue-500/10 text-blue-400 border-blue-500/20" ,
                                                icon: "M5 13l4 4L19 7" }; } else if (order.status==='cancelled' ) {
                                                statusConfig={ class: "bg-rose-500/10 text-rose-500 border-rose-500/20"
                                                , icon: "M6 18L18 6M6 6l12 12" }; } %>
                                                <div
                                                    class="flex items-center gap-2 px-4 py-2 rounded-2xl border <%= statusConfig.class %> transition-all duration-500">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor"
                                                        viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round"
                                                            stroke-width="2.5" d="<%= statusConfig.icon %>"></path>
                                                    </svg>
                                                    <span class="text-[10px] font-black uppercase tracking-widest">
                                                        <%= (order.status || 'Processing' ).replace(/_/g, ' ' ) %>
                                                    </span>
                                                </div>
                                        </div>

                                        <!-- Middle Row: Info & Amount -->
                                        <div
                                            class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center bg-white/5 rounded-3xl p-6 border border-white/5">
                                            <div class="flex flex-col gap-1">
                                                <p
                                                    class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">
                                                    Purchase Date</p>
                                                <p class="font-bold text-white">
                                                    <%= new Date(order.orderDate ||
                                                        order.createdAt).toLocaleDateString('en-US', { month: 'long' ,
                                                        day: 'numeric' , year: 'numeric' }) %>
                                                </p>
                                            </div>
                                            <div class="flex flex-col gap-1">
                                                <p
                                                    class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">
                                                    Billing Email</p>
                                                <p class="font-bold text-white truncate max-w-[200px]">
                                                    <%= order.customerEmail %>
                                                </p>
                                            </div>
                                            <div class="flex flex-col gap-1 md:items-end">
                                                <p
                                                    class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">
                                                    Total Amount</p>
                                                <p class="text-3xl font-black text-blue-400 tracking-tighter">$<%=
                                                        (order.total_amount || order.total || 0).toFixed(2) %>
                                                </p>
                                            </div>
                                        </div>

                                        <!-- Bottom Row: Items & CTA -->
                                        <div class="flex flex-col sm:flex-row items-center justify-between gap-8">
                                            <div
                                                class="flex items-center gap-2 overflow-x-auto no-scrollbar pb-2 w-full sm:w-auto">
                                                <% if (order.items && order.items.length> 0) { %>
                                                    <% order.items.forEach((item, idx)=> { %>
                                                        <% if (idx < 4) { %>
                                                            <div class="relative group/item flex-shrink-0">
                                                                <div
                                                                    class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 p-1 flex items-center justify-center shadow-sm hover:shadow-md transition-all">
                                                                    <img src="<%= item.imageUrl || item.image || 'https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&fit=crop&q=80&w=200' %>"
                                                                        alt="<%= item.name || item.productName %>"
                                                                        class="w-full h-full object-cover rounded-xl">
                                                                </div>
                                                                <span
                                                                    class="absolute -top-1.5 -right-1.5 bg-blue-600 border-2 border-slate-900 text-white text-[9px] font-black w-5 h-5 flex items-center justify-center rounded-full">
                                                                    <%= item.quantity %>
                                                                </span>
                                                                <!-- Tooltip -->
                                                                <div
                                                                    class="absolute -bottom-10 left-1/2 -translate-x-1/2 px-2 py-1 bg-slate-900 text-white text-[9px] font-bold rounded-lg opacity-0 group-hover/item:opacity-100 transition-opacity pointer-events-none whitespace-nowrap z-10">
                                                                    <%= item.name || item.productName %>
                                                                </div>
                                                            </div>
                                                            <% } %>
                                                                <% }) %>
                                                                    <% if (order.items.length> 4) { %>
                                                                        <div
                                                                            class="w-14 h-14 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center text-slate-400 font-black text-xs">
                                                                            +<%= order.items.length - 4 %>
                                                                        </div>
                                                                        <% } %>
                                                                            <% } %>
                                            </div>

                                            <a href="/my-orders/<%= order.id %>"
                                                class="w-full sm:w-auto px-10 py-4 bg-primary text-slate-950 font-black text-[11px] uppercase tracking-[0.2em] rounded-2xl hover:bg-blue-600 hover:text-white hover:shadow-xl hover:shadow-blue-600/20 transition-all duration-500 text-center">
                                                View Receipt
                                            </a>
                                        </div>
                                    </div>

                                    <!-- Decorative Gradient Overlay -->
                                    <div
                                        class="absolute bottom-0 right-0 w-32 h-32 bg-gradient-to-br from-blue-500/0 to-blue-500/10 rounded-full -mr-16 -mb-16 group-hover:scale-150 transition-transform duration-1000">
                                    </div>
                                </div>
                                <% }) %>
                        </div>
                        <% } else { %>
                            <!-- Enhanced Empty State -->
                            <div
                                class="bg-slate-900 rounded-[4rem] p-16 sm:p-24 shadow-2xl border border-white/5 text-center animate-fade-in relative overflow-hidden">
                                <div
                                    class="absolute -top-20 -right-20 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl animate-pulse">
                                </div>
                                <div class="relative w-32 h-32 mx-auto mb-10">
                                    <div
                                        class="absolute inset-0 bg-blue-600/20 rounded-[2.5rem] rotate-6 animate-pulse">
                                    </div>
                                    <div
                                        class="absolute inset-0 bg-blue-600 rounded-[2.5rem] -rotate-3 flex items-center justify-center shadow-2xl shadow-blue-500/40">
                                        <svg class="w-14 h-14 text-white" fill="none" stroke="currentColor"
                                            viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                                        </svg>
                                    </div>
                                </div>
                                <h2 class="text-4xl font-black text-white mb-6 tracking-tight">Your cart is feeling
                                    lonely.</h2>
                                <p class="text-slate-400 font-medium text-lg mb-10 max-w-lg mx-auto leading-relaxed">
                                    It looks like you haven't started your RD Fresh journey yet. Discover our premium
                                    selection and place your first order today.
                                </p>
                                <a href="javascript:void(0)"
                                    class="group relative inline-flex items-center gap-3 px-12 py-6 bg-slate-800 text-slate-400 font-black uppercase tracking-widest rounded-3xl cursor-default border border-white/5">
                                    Start Shopping
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                                    </svg>
                                </a>
                            </div>
                            <% } %>
                </div>
            </main>

            <%- include('partials/footer') %>

                <style>
                    .no-scrollbar::-webkit-scrollbar {
                        display: none;
                    }

                    .no-scrollbar {
                        -ms-overflow-style: none;
                        scrollbar-width: none;
                    }

                    @keyframes fadeUp {
                        from {
                            opacity: 0;
                            transform: translateY(30px);
                        }

                        to {
                            opacity: 1;
                            transform: translateY(0);
                        }
                    }

                    .order-card {
                        will-change: transform, opacity;
                    }

                    /* Smooth custom tooltips logic */
                    .group\/item:hover div {
                        transition-delay: 100ms;
                    }
                </style>
    </body>

</html>