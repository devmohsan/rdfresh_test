<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rdfresh | View Inquiry</title>
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .animate-entry {
            animation: fadeIn 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
            opacity: 0;
        }

        .delay-1 {
            animation-delay: 0.1s;
        }
    </style>
</head>

<body class="bg-[#F8FAFC]">
    <div class="flex h-screen overflow-hidden">
        <%- include('partials/sidebar') %>

            <div class="relative flex flex-col flex-1 overflow-x-hidden overflow-y-auto">
                <%- include('partials/header') %>

                    <main class="flex-1 p-8">
                        <div class="max-w-4xl mx-auto">
                            <!-- Header -->
                            <div class="flex items-center justify-between mb-10 animate-entry">
                                <div>
                                    <nav class="flex mb-4" aria-label="Breadcrumb">
                                        <ol
                                            class="inline-flex items-center space-x-1 md:space-x-3 text-xs font-bold uppercase tracking-widest text-[#64748b]">
                                            <li><a href="/admin/inquiries"
                                                    class="hover:text-blue-600 transition-colors">Inquiries</a></li>
                                            <li>
                                                <div class="flex items-center">
                                                    <svg class="w-3 h-3 text-slate-300 mx-1" fill="currentColor"
                                                        viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd"
                                                            d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                                            clip-rule="evenodd"></path>
                                                    </svg>
                                                    <span class="text-slate-900"><%= inquiry.type === 'affiliate' ? 'Affiliate' : 'Distributor' %> Details</span>
                                                </div>
                                            </li>
                                        </ol>
                                    </nav>
                                    <h1 class="text-4xl font-black text-slate-900 tracking-tight">Inquiry Profile</h1>
                                </div>
                                <a href="/admin/inquiries"
                                    class="px-6 py-3 bg-white border border-slate-200 text-slate-600 font-black text-[10px] uppercase tracking-widest rounded-2xl hover:bg-slate-50 transition-all shadow-sm">
                                    Back to List
                                </a>
                            </div>

                            <div class="grid grid-cols-1 gap-8 animate-entry delay-1">
                                <!-- Identity Card -->
                                <div
                                    class="bg-white rounded-[2.5rem] border border-slate-100 shadow-[0_20px_50px_rgba(0,0,0,0.02)] p-10">
                                    <div class="flex items-center gap-8 mb-12">
                                        <div
                                            class="w-24 h-24 bg-blue-600 rounded-[2rem] flex items-center justify-center text-white text-3xl font-black shadow-xl shrink-0">
                                            <%= inquiry.name.charAt(0).toUpperCase() %>
                                        </div>
                                        <div class="flex-1">
                                            <div class="flex items-center justify-between mb-2">
                                                <h2 class="text-3xl font-black text-slate-900 tracking-tight">
                                                    <%= inquiry.name %>
                                                </h2>
                                                <span class="inline-flex items-center px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-wider
                                            <%= inquiry.status === 'pending' ? 'bg-amber-50 text-amber-600 border border-amber-100' : 
                                               inquiry.status === 'approved' ? 'bg-emerald-50 text-emerald-600 border border-emerald-100' :
                                               'bg-rose-50 text-rose-600 border border-rose-100' %>">
                                                    Status: <%= inquiry.status %>
                                                </span>
                                            </div>
                                            <p class="<%= inquiry.type === 'affiliate' ? 'text-emerald-600' : 'text-blue-600' %> font-black uppercase tracking-widest text-xs">
                                                <%= inquiry.type === 'affiliate' ? (inquiry.platformType + ' Influencer') : inquiry.businessType %>
                                            </p>
                                            <p class="text-slate-400 font-medium text-sm mt-1">Submitted on <%= new
                                                    Date(inquiry.createdAt).toLocaleString() %>
                                            </p>
                                        </div>
                                    </div>

                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                                        <div class="space-y-8">
                                            <div>
                                                <label
                                                    class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-3">Enterprise
                                                    Identity</label>
                                                <p class="text-slate-900 font-bold text-lg">
                                                    <%= inquiry.businessName %>
                                                </p>
                                            </div>
                                            <div>
                                                <label
                                                    class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-3">Website
                                                    Protocol</label>
                                                <p class="text-slate-900 font-bold text-lg">
                                                    <% if (inquiry.websiteUrl) { %>
                                                        <a href="<%= inquiry.websiteUrl.startsWith('http') ? inquiry.websiteUrl : 'https://' + inquiry.websiteUrl %>"
                                                            target="_blank"
                                                            class="text-blue-600 hover:underline flex items-center gap-2">
                                                            <%= inquiry.websiteUrl %>
                                                                <i class="fas fa-external-link-alt text-[10px]"></i>
                                                        </a>
                                                        <% } else { %>
                                                            <span
                                                                class="text-slate-400 italic font-medium text-base">Not
                                                                Provided</span>
                                                            <% } %>
                                                </p>
                                            </div>
                                            <div>
                                                <label
                                                    class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-3">Email
                                                    Protocol</label>
                                                <p class="text-slate-900 font-bold text-lg">
                                                    <%= inquiry.email %>
                                                </p>
                                            </div>
                                            <div>
                                                <label
                                                    class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-3"><%= inquiry.type === 'affiliate' ? 'Social Platform' : 'Secure Contact' %></label>
                                                <p class="text-slate-900 font-bold text-lg">
                                                    <%= inquiry.type === 'affiliate' ? inquiry.platformType : inquiry.phone %>
                                                </p>
                                            </div>
                                        </div>
                                        <div class="space-y-8">
                                            <div>
                                                <label
                                                    class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-3"><%= inquiry.type === 'affiliate' ? 'Audience Stats' : 'Geographical HQ' %></label>
                                                <p class="text-slate-900 font-bold text-lg leading-relaxed">
                                                    <%= inquiry.type === 'affiliate' ? inquiry.audienceSize : inquiry.address %>
                                                </p>
                                            </div>
                                            <% if (inquiry.message) { %>
                                                <div>
                                                    <label
                                                        class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-3">Narrative
                                                        / Message</label>
                                                    <div
                                                        class="p-6 bg-slate-50 rounded-2xl text-slate-700 font-medium italic border border-slate-100 text-sm leading-relaxed">
                                                        "<%= inquiry.message %>"
                                                    </div>
                                                </div>
                                                <% } %>
                                        </div>
                                    </div>

                                    <div class="mt-12 pt-10 border-t border-slate-50 flex items-center gap-4">
                                        <% if (inquiry.status==='pending' ) { %>
                                            <form action="/admin/inquiries/approve/<%= inquiry.id %>?type=<%= inquiry.type %>" method="POST"
                                                class="flex-1">
                                                <button type="submit"
                                                    class="w-full py-5 bg-emerald-500 text-white font-black uppercase tracking-[0.2em] text-[11px] rounded-[1.5rem] hover:bg-emerald-600 transition-all shadow-xl shadow-emerald-500/20 flex items-center justify-center gap-3">
                                                    <i class="fas fa-check-circle"></i>
                                                    Approve Partnership
                                                </button>
                                            </form>
                                            <% } %>
                                                <form action="/admin/inquiries/delete/<%= inquiry.id %>?type=<%= inquiry.type %>" method="POST"
                                                    class="<%= inquiry.status === 'pending' ? 'w-1/3' : 'w-full' %>">
                                                    <button type="submit"
                                                        class="w-full py-5 bg-white border border-slate-100 text-rose-500 font-black uppercase tracking-[0.2em] text-[11px] rounded-[1.5rem] hover:bg-rose-50 hover:border-rose-100 transition-all shadow-sm flex items-center justify-center gap-3">
                                                        <i class="fas fa-trash-alt"></i>
                                                        Remove Record
                                                    </button>
                                                </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </main>
            </div>
    </div>
</body>

</html>