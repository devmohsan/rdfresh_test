<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rdfresh | Edit Order Items</title>
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.05);
            border-radius: 10px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(0, 0, 0, 0.1);
            border-radius: 10px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(0, 0, 0, 0.2);
        }
    </style>
</head>

<body class="bg-[#F8FAFC]">
    <div class="flex h-screen overflow-hidden">
        <%- include('partials/sidebar') %>

            <div class="relative flex flex-col flex-1 overflow-x-hidden overflow-y-auto">
                <%- include('partials/header') %>

                    <main class="flex-1 p-8 pb-32">
                        <div class="max-w-6xl mx-auto space-y-8">

                            <!-- Header & Actions -->
                            <div class="flex items-center justify-between">
                                <div class="flex items-center gap-4">
                                    <a href="/orders/view/<%= order.id %>"
                                        class="w-10 h-10 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:text-slate-900 hover:border-slate-300 transition-all shadow-sm">
                                        <i class="fas fa-arrow-left"></i>
                                    </a>
                                    <div>
                                        <h1 class="text-2xl font-black text-slate-900 tracking-tight">Modify Order</h1>
                                        <div class="flex items-center gap-2 mt-1">
                                            <span
                                                class="px-2 py-0.5 rounded text-[10px] font-bold bg-slate-100 text-slate-500 uppercase tracking-widest border border-slate-200">
                                                #<%= order.orderNumber %>
                                            </span>
                                            <span class="text-xs text-slate-400 font-medium">
                                                <%= new Date(order.orderDate).toLocaleDateString() %>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                <div class="flex items-center gap-3">
                                    <div class="text-right mr-4">
                                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Grand
                                            Total</p>
                                        <p class="text-2xl font-black text-slate-900" id="headerTotal">$0.00</p>
                                    </div>
                                    <button onclick="document.getElementById('orderForm').submit()"
                                        class="px-6 py-2.5 bg-emerald-500 hover:bg-emerald-400 text-white rounded-xl font-bold text-xs uppercase tracking-widest shadow-lg shadow-emerald-500/20 transition-all transform hover:-translate-y-0.5 flex items-center gap-2">
                                        <i class="fas fa-save"></i>
                                        Save Changes
                                    </button>
                                </div>
                            </div>

                            <!-- Order Details Summary -->
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                                <!-- Customer -->
                                <div
                                    class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm flex items-start gap-3">
                                    <div
                                        class="w-8 h-8 rounded-lg bg-blue-50 text-blue-500 flex items-center justify-center flex-shrink-0">
                                        <i class="fas fa-user text-xs"></i>
                                    </div>
                                    <div class="overflow-hidden">
                                        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">
                                            Customer</h3>
                                        <p class="font-bold text-slate-900 truncate">
                                            <%= order.user?.name || 'Guest' %>
                                        </p>
                                        <p class="text-xs text-slate-500 truncate">
                                            <%= order.user?.email %>
                                        </p>
                                    </div>
                                </div>
                                <!-- Ship To -->
                                <div
                                    class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm flex items-start gap-3">
                                    <div
                                        class="w-8 h-8 rounded-lg bg-purple-50 text-purple-500 flex items-center justify-center flex-shrink-0">
                                        <i class="fas fa-map-marker-alt text-xs"></i>
                                    </div>
                                    <div class="overflow-hidden">
                                        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">
                                            Shipping To</h3>
                                        <p class="font-bold text-slate-900 truncate">
                                            <%= order.shipTo?.name %>
                                        </p>
                                        <p class="text-xs text-slate-500 truncate">
                                            <%= order.shipTo?.city %>, <%= order.shipTo?.state %>
                                        </p>
                                    </div>
                                </div>
                                <!-- Status -->
                                <div
                                    class="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm flex items-start gap-3">
                                    <div
                                        class="w-8 h-8 rounded-lg bg-emerald-50 text-emerald-500 flex items-center justify-center flex-shrink-0">
                                        <i class="fas fa-info-circle text-xs"></i>
                                    </div>
                                    <div>
                                        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">
                                            Current Status</h3>
                                        <span
                                            class="inline-flex px-2 py-1 rounded-md text-[10px] font-bold uppercase tracking-widest bg-slate-100/80 text-slate-600 border border-slate-200">
                                            <%= order.status %>
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <!-- Form Wrapper -->
                            <form id="orderForm" action="/admin/orders/update/<%= order.id %>" method="POST"
                                onsubmit="console.log('Submitting form with items:', cart)">
                                <div id="hiddenInputsContainer"></div>

                                <!-- CURRENT ITEMS SECTION -->
                                <div
                                    class="bg-white rounded-[2rem] border border-slate-100 shadow-sm overflow-hidden mb-8">
                                    <div
                                        class="px-8 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                                        <div class="flex items-center gap-3">
                                            <div
                                                class="w-8 h-8 bg-slate-900 rounded-lg flex items-center justify-center text-white">
                                                <i class="fas fa-shopping-bag text-xs"></i>
                                            </div>
                                            <div>
                                                <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest">
                                                    Current Order Items</h3>
                                                <p class="text-[10px] font-bold text-slate-500">Items currently in this
                                                    order</p>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="overflow-x-auto">
                                        <table class="w-full text-left">
                                            <thead>
                                                <tr
                                                    class="text-[10px] font-black text-slate-400 uppercase tracking-widest bg-slate-50/50 border-b border-slate-100">
                                                    <th class="px-8 py-3 w-16">#</th>
                                                    <th class="px-8 py-3">Product</th>
                                                    <th class="px-8 py-3 text-right">Price</th>
                                                    <th class="px-8 py-3 text-center">Quantity</th>
                                                    <th class="px-8 py-3 text-right">Total</th>
                                                    <th class="px-8 py-3 w-16 text-center"></th>
                                                </tr>
                                            </thead>
                                            <tbody id="cartTableBody" class="divide-y divide-slate-50">
                                                <!-- Cart items rendered via JS -->
                                            </tbody>
                                        </table>
                                        <div id="emptyCartMessage" class="hidden py-12 text-center">
                                            <div
                                                class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4 text-slate-300">
                                                <i class="fas fa-shopping-basket text-2xl"></i>
                                            </div>
                                            <p class="text-sm font-bold text-slate-500">No items in this order.</p>
                                            <p class="text-xs text-slate-400 mt-1">Add products from the catalog below.
                                            </p>
                                        </div>
                                    </div>

                                    <!-- Summary Footer -->
                                    <div class="px-8 py-4 bg-slate-50 border-t border-slate-100 flex justify-end">
                                        <div class="text-right w-48">
                                            <div class="flex justify-between items-center mb-1">
                                                <span class="text-xs font-bold text-slate-500">Subtotal</span>
                                                <span class="text-sm font-bold text-slate-900"
                                                    id="cartSubtotal">$0.00</span>
                                            </div>
                                            <div class="flex justify-between items-center mb-1">
                                                <span class="text-xs font-bold text-slate-500">Estimated Tax</span>
                                                <span class="text-xs font-bold text-slate-400">Calculated by SS</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>

                            <!-- CATALOG SECTION -->
                            <div
                                class="bg-white rounded-[2rem] border border-slate-100 shadow-sm overflow-hidden flex flex-col h-[600px]">
                                <div
                                    class="px-8 py-5 border-b border-slate-100 flex items-center justify-between bg-emerald-50/50 flex-shrink-0">
                                    <div class="flex items-center gap-3">
                                        <div
                                            class="w-8 h-8 bg-emerald-500 rounded-lg flex items-center justify-center text-white">
                                            <i class="fas fa-cubes text-xs"></i>
                                        </div>
                                        <div>
                                            <h3 class="text-sm font-black text-slate-900 uppercase tracking-widest">
                                                Product Catalog</h3>
                                            <p class="text-[10px] font-bold text-slate-500">Click + to add to order</p>
                                        </div>
                                    </div>
                                    <div class="relative">
                                        <input type="text" id="productSearch" placeholder="Search by name or SKU..."
                                            class="px-4 py-2 bg-white rounded-xl border border-transparent focus:border-emerald-500 focus:outline-none text-xs font-bold text-slate-700 w-72 shadow-sm placeholder-slate-400 ring-4 ring-transparent focus:ring-emerald-500/10 transition-all">
                                        <i
                                            class="fas fa-search absolute right-4 top-2.5 text-slate-300 pointer-events-none text-xs"></i>
                                    </div>
                                </div>

                                <div class="overflow-y-auto custom-scrollbar flex-1 relative">
                                    <table class="w-full text-left">
                                        <thead class="sticky top-0 bg-white/95 backdrop-blur z-10 shadow-sm">
                                            <tr class="text-[10px] font-black text-slate-400 uppercase tracking-widest">
                                                <th class="px-8 py-3 w-16">Img</th>
                                                <th class="px-8 py-3">Product Details</th>
                                                <th class="px-8 py-3 text-right">Unit Price</th>
                                                <th class="px-8 py-3 w-24 text-center">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-slate-50" id="catalogTableBody">
                                            <!-- Catalog items rendered via JS -->
                                        </tbody>
                                    </table>
                                    <div id="noResultsMessage" class="hidden py-20 text-center">
                                        <p class="text-sm font-bold text-slate-400">No products found matching your
                                            search.</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Spacer for bottom padding -->
                            <div class="h-8"></div>
                        </div>
                    </main>
            </div>
    </div>

