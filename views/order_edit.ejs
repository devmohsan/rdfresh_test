    <!-- Data Injection (Cleaner Method) -->
    <script id="order-items-data" type="application/json">
        <%- JSON.stringify(order.items || []) %>
    </script>
    <script id="products-data" type="application/json">
        <%- JSON.stringify(products || []) %>
    </script>

    <script>
        // --- Data Initialization (Clean & Robust) ---
        // Parsing data from JSON script tags avoids syntax errors and linting issues
        const initialOrderItems = JSON.parse(document.getElementById('order-items-data').textContent);
        const allProducts = JSON.parse(document.getElementById('products-data').textContent);

        console.log('Initial Order Items:', initialOrderItems);
        console.log('All Products:', allProducts);

        // Clean up catalog data
        const catalog = allProducts.map(p => {
            // Handle missing or malformed products
            if (!p) return null;

            return {
                sku: p.sku || 'N/A',
                name: p.name || 'Unnamed Product',
                price: parseFloat(p.price) || 0,
                imageUrl: p.thumbnailUrl || p.imageUrl || null,
                displayImg: (function (url) {
                    if (!url || url === 'null' || url === 'undefined') return null;
                    if (url.startsWith('http')) return url;
                    if (url.startsWith('www')) return 'https://' + url;
                    return url;
                })(p.thumbnailUrl || p.imageUrl)
            };
        }).filter(p => p !== null); // Remove null entries

        console.log('Processed Catalog:', catalog);

        // Initialize state
        let cart = initialOrderItems.map(item => {
            if (!item) return null;

            return {
                lineItemKey: item.lineItemKey || null,
                sku: item.sku || 'N/A',
                name: item.name || 'Unknown Product',
                price: parseFloat(item.price) || 0,
                quantity: parseInt(item.quantity) || 1,
                imageUrl: item.imageUrl || null,
                displayImg: (function (url) {
                    if (!url || url === 'null' || url === 'undefined') return null;
                    if (url.startsWith('http')) return url;
                    if (url.startsWith('www')) return 'https://' + url;
                    return url;
                })(item.imageUrl)
            };
        }).filter(item => item !== null); // Remove null entries

        console.log('Initial Cart:', cart);

        // DOM Elements
        const cartTableBody = document.getElementById('cartTableBody');
        const catalogTableBody = document.getElementById('catalogTableBody');
        const hiddenInputsContainer = document.getElementById('hiddenInputsContainer');
        const cartSubtotalEl = document.getElementById('cartSubtotal');
        const headerTotalEl = document.getElementById('headerTotal');
        const emptyCartMessage = document.getElementById('emptyCartMessage');
        const productSearch = document.getElementById('productSearch');
        const noResultsMessage = document.getElementById('noResultsMessage');

        // --- Functions ---

        function formatMoney(amount) {
            if (isNaN(amount)) amount = 0;
            return '$' + amount.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        function renderCart() {
            console.log('Rendering cart with items:', cart);
            cartTableBody.innerHTML = '';
            hiddenInputsContainer.innerHTML = '';
            let total = 0;

            if (cart.length === 0) {
                emptyCartMessage.classList.remove('hidden');
            } else {
                emptyCartMessage.classList.add('hidden');

                cart.forEach((item, index) => {
                    // Validate item
                    if (!item) return;

                    // Update totals
                    const itemTotal = (item.price || 0) * (item.quantity || 1);
                    total += itemTotal;

                    // 1. Create Table Row
                    const tr = document.createElement('tr');
                    tr.className = 'group hover:bg-slate-50/50 transition-colors';
                    tr.innerHTML = `
                    <td class="px-8 py-4 text-slate-400 font-bold text-xs w-16">${index + 1}</td>
                    <td class="px-8 py-4">
                        <div class="flex items-center gap-4">
                            ${item.displayImg
                            ? `<img src="${item.displayImg}" class="w-10 h-10 rounded-lg object-cover border border-slate-100 bg-white" alt="${item.name}">`
                            : `<div class="w-10 h-10 rounded-lg bg-slate-100 flex items-center justify-center text-slate-300"><i class="fas fa-box text-xs"></i></div>`
                        }
                            <div>
                                <p class="font-black text-slate-900 text-sm leading-tight">${item.name}</p>
                                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-0.5">SKU: ${item.sku}</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-8 py-4 text-right font-bold text-slate-500 text-xs">${formatMoney(item.price)}</td>
                    <td class="px-8 py-4 text-center">
                        <div class="inline-flex items-center bg-white border border-slate-200 rounded-lg shadow-sm">
                            <button type="button" onclick="updateQuantity(${index}, -1)" class="w-8 h-8 flex items-center justify-center text-slate-400 hover:text-red-500 transition-colors">
                                <i class="fas fa-minus text-[10px]"></i>
                            </button>
                            <input type="number" min="1" value="${item.quantity}" 
                                onchange="setQuantity(${index}, this.value)"
                                class="w-10 text-center text-xs font-bold text-slate-900 border-none focus:ring-0 p-0">
                            <button type="button" onclick="updateQuantity(${index}, 1)" class="w-8 h-8 flex items-center justify-center text-slate-400 hover:text-emerald-500 transition-colors">
                                <i class="fas fa-plus text-[10px]"></i>
                            </button>
                        </div>
                    </td>
                    <td class="px-8 py-4 text-right font-black text-slate-900 text-sm">${formatMoney(itemTotal)}</td>
                    <td class="px-8 py-4 text-center w-16">
                        <button type="button" onclick="removeItem(${index})" 
                            class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-300 hover:text-red-500 hover:bg-red-50 transition-all">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </td>
                `;
                    cartTableBody.appendChild(tr);

                    // 2. Create Hidden Inputs for Form Submission
                    hiddenInputsContainer.innerHTML += `
                    <input type="hidden" name="items[${index}][lineItemKey]" value="${item.lineItemKey || ''}">
                    <input type="hidden" name="items[${index}][sku]" value="${item.sku}">
                    <input type="hidden" name="items[${index}][name]" value="${item.name}">
                    <input type="hidden" name="items[${index}][quantity]" value="${item.quantity}">
                    <input type="hidden" name="items[${index}][price]" value="${item.price}">
                    <input type="hidden" name="items[${index}][imageUrl]" value="${item.imageUrl || ''}">
                `;
                });
            }

            // Update Summaries
            cartSubtotalEl.innerText = formatMoney(total);
            headerTotalEl.innerText = formatMoney(total);
        }

        function renderCatalog(filter = '') {
            console.log('Rendering catalog with filter:', filter);
            catalogTableBody.innerHTML = '';
            const lowerFilter = filter.toLowerCase();
            let hasResults = false;

            if (catalog.length === 0) {
                console.log('Catalog is empty!');
                // Show empty catalog message
                catalogTableBody.innerHTML = `
                                            <tr>
                                                <td colspan="4" class="px-8 py-8 text-center">
                                                    <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4 text-slate-300">
                                                        <i class="fas fa-box-open text-2xl"></i>
                                                    </div>
                                                    <p class="text-sm font-bold text-slate-500">No products available in catalog.</p>
                                                    <p class="text-xs text-slate-400 mt-1">Check your product data source.</p>
                                                </td>
                                            </tr>
                                            `;
                return;
            }

            for (const p of catalog) {
                if (!p) continue;

                if (lowerFilter &&
                    !p.name.toLowerCase().includes(lowerFilter) &&
                    !p.sku.toLowerCase().includes(lowerFilter)) {
                    continue;
                }

                hasResults = true;

                const tr = document.createElement('tr');
                tr.className = 'group hover:bg-slate-50/50 transition-colors border-b border-slate-50 last:border-0';

                tr.innerHTML = `
                                            <td class="px-8 py-3 w-16">
                                                ${p.displayImg
                        ? `<img src="${p.displayImg}" class="w-8 h-8 rounded shadow-sm object-cover" alt="${p.name}">`
                        : `<div class="w-8 h-8 rounded bg-slate-100 flex items-center justify-center text-slate-300"><i class="fas fa-box text-[10px]"></i></div>`
                    }
                                            </td>
                                            <td class="px-8 py-3">
                                                <p class="font-bold text-slate-700 text-xs leading-tight group-hover:text-slate-900 transition-colors">${p.name}</p>
                                                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mt-0.5">SKU: ${p.sku}</p>
                                            </td>
                                            <td class="px-8 py-3 text-right font-bold text-slate-500 text-xs">${formatMoney(p.price)}</td>
                                            <td class="px-8 py-3 w-24 text-center">
                                                <button type="button" onclick="addToCart('${p.sku}')"
                                                    class="px-3 py-1.5 bg-white border border-slate-200 text-slate-600 rounded-lg text-[10px] font-bold uppercase tracking-widest hover:bg-emerald-500 hover:text-white hover:border-emerald-500 transition-all shadow-sm">
                                                    <i class="fas fa-plus mr-1"></i> Add
                                                </button>
                                            </td>
            `;
                catalogTableBody.appendChild(tr);
            }

            if (!hasResults && lowerFilter) {
                noResultsMessage.classList.remove('hidden');
            } else {
                noResultsMessage.classList.add('hidden');
            }
        }

        // --- Interaction Handlers ---

        window.addToCart = function (sku) {
            console.log('Adding to cart SKU:', sku);
            const product = catalog.find(p => p.sku === sku);
            if (!product) {
                console.error('Product not found:', sku);
                return;
            }

            const existingItem = cart.find(i => i.sku === sku);
            if (existingItem) {
                existingItem.quantity += 1;
            } else {
                cart.push({
                    lineItemKey: null,
                    sku: product.sku,
                    name: product.name,
                    price: product.price,
                    quantity: 1,
                    imageUrl: product.imageUrl,
                    displayImg: product.displayImg
                });
            }
            renderCart();
        };

        window.removeItem = function (index) {
            if (index >= 0 && index < cart.length) {
                cart.splice(index, 1);
                renderCart();
            }
        };

        window.updateQuantity = function (index, delta) {
            const item = cart[index];
            if (!item) return;

            const newQty = item.quantity + delta;
            if (newQty <= 0) {
                window.removeItem(index);
            } else {
                item.quantity = newQty;
                renderCart();
            }
        };

        window.setQuantity = function (index, value) {
            const qty = parseInt(value);
            if (isNaN(qty) || qty <= 0) {
                if (confirm("Remove this item?")) {
                    window.removeItem(index);
                } else {
                    renderCart(); // Revert to previous value
                }
            } else {
                cart[index].quantity = qty;
                renderCart();
            }
        };

        // --- Event Listeners ---

        if (productSearch) {
            productSearch.addEventListener('input', (e) => {
                renderCatalog(e.target.value);
            });
        }

        // --- Init ---
        renderCart();
        renderCatalog();

        // Debug: Check if elements exist
        console.log('DOM Elements found:');
        console.log('- cartTableBody:', !!cartTableBody);
        console.log('- catalogTableBody:', !!catalogTableBody);
        console.log('- catalog items count:', catalog.length);
        console.log('- cart items count:', cart.length);
    </script>
</body>

</html>