<div
  class="bg-white/90 backdrop-blur-xl border-b border-slate-100 px-8 py-5 flex items-center justify-between sticky top-0 z-40 transition-all duration-300">
  <!-- Left: Controls + Branding -->
  <div class="flex items-center gap-6">
    <!-- Desktop Toggle -->
    <button id="sidebarToggleDesktop"
      class="hidden md:flex p-2.5 rounded-2xl bg-slate-50 text-slate-400 hover:bg-emerald-50 hover:text-emerald-600 transition-all duration-300 border border-slate-100 group">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:-translate-x-0.5 transition-transform"
        fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12" />
      </svg>
    </button>

    <!-- Mobile Toggle -->
    <button id="sidebarToggle" class="md:hidden p-2.5 rounded-xl bg-slate-50 text-slate-600 border border-slate-100">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"
        stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <div class="flex flex-col">
      <div class="flex items-center gap-3">
        <img src="/images/new-logo.png" alt="Rdfresh Logo" class="h-10 w-auto object-contain">
        <!-- <div class="h-6 w-[1.5px] bg-slate-200"></div> -->
        <!-- <h1 class="text-xl font-black text-slate-900 tracking-tight leading-none uppercase">Rdfresh</h1> -->
        <!-- <div class="h-4 w-[1px] bg-slate-200"></div> -->
        <!-- <span class="text-[10px] font-black text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-full tracking-widest uppercase">Console</span> -->
      </div>
      <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mt-1.5 opacity-80">Operational
        Intelligence</p>
    </div>
  </div>

  <!-- Right: Notifications + Admin Profile -->
  <div class="flex items-center gap-6">
    <!-- Notifications -->
    <div class="relative">
      <button id="notificationBtn"
        class="relative p-3 rounded-2xl bg-slate-50 text-slate-500 hover:bg-emerald-50 hover:text-emerald-600 transition-all duration-300 border border-slate-100 group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
          stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0a3 3 0 11-6 0m6 0H9" />
        </svg>
        <span id="notificationBadge"
          class="hidden absolute -top-1 -right-1 min-w-[18px] h-[18px] px-1.5 rounded-full bg-rose-500 text-white text-[10px] font-black leading-[18px] text-center border-2 border-white"></span>
      </button>

      <div id="notificationMenu"
        class="absolute right-0 mt-4 w-[22rem] bg-white border border-slate-100 rounded-[2.5rem] shadow-[0_30px_100px_rgba(0,0,0,0.1)] hidden z-50 overflow-hidden transform opacity-0 scale-95 transition-all duration-300 shadow-emerald-900/10">
        <div class="px-8 py-6 bg-slate-50 border-b border-slate-100">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-xs font-black text-slate-900 uppercase tracking-widest">Notifications</p>
              <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mt-1">Auto-sync every 5 seconds
              </p>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
              <span class="text-[10px] font-black text-emerald-600 uppercase tracking-widest">Live</span>
            </div>
          </div>
        </div>

        <div class="max-h-[22rem] overflow-y-auto">
          <div id="notificationList" class="divide-y divide-slate-50"></div>
          <div id="notificationEmpty" class="px-8 py-12 text-center hidden">
            <div
              class="w-12 h-12 bg-slate-50 rounded-full flex items-center justify-center text-slate-300 mb-4 mx-auto">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0a3 3 0 11-6 0m6 0H9" />
              </svg>
            </div>
            <p class="text-slate-400 font-bold uppercase tracking-widest">No notifications</p>
          </div>
        </div>
      </div>
    </div>

    <div class="relative">
      <button id="adminDropdownBtn"
        class="flex items-center gap-3 p-1.5 pr-4 rounded-[1.5rem] border border-slate-100 hover:border-emerald-100 hover:bg-emerald-50/50 transition-all duration-300 group">
        <div class="relative">
          <div
            class="h-10 w-10 rounded-2xl bg-slate-900 flex items-center justify-center text-emerald-400 font-black text-sm shadow-xl group-hover:bg-emerald-500 group-hover:text-white transition-all duration-300">
            <%= (admin.name || 'A' ).charAt(0).toUpperCase() %>
          </div>
          <div class="absolute -bottom-1 -right-1 w-4 h-4 bg-emerald-500 border-2 border-white rounded-full"></div>
        </div>

        <div class="text-left hidden sm:block">
          <p class="text-xs font-black text-slate-900 leading-none mb-1">
            <%= admin.name || 'Administrator' %>
          </p>
          <p class="text-[9px] font-bold text-slate-400 uppercase tracking-tighter">Administrator</p>
        </div>

        <svg class="w-4 h-4 text-slate-300 group-hover:text-emerald-500 transition-all group-hover:translate-y-0.5"
          fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <!-- Dropdown -->
      <div id="adminDropdownMenu"
        class="absolute right-0 mt-4 w-72 bg-white border border-slate-100 rounded-[2.5rem] shadow-[0_30px_100px_rgba(0,0,0,0.1)] py-2 hidden z-50 overflow-hidden transform opacity-0 scale-95 transition-all duration-300 shadow-emerald-900/10">
        <div class="px-8 py-7 bg-slate-50 border-b border-slate-100">
          <div class="flex items-center gap-4 mb-4">
            <div
              class="h-12 w-12 rounded-2xl bg-slate-900 flex items-center justify-center text-emerald-400 font-black text-lg">
              <%= (admin.name || 'A' ).charAt(0).toUpperCase() %>
            </div>
            <div>
              <p class="text-sm font-black text-slate-900">
                <%= admin.name || 'Administrator' %>
              </p>
              <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest leading-none mt-1">Full Control
                Access</p>
            </div>
          </div>
          <div class="bg-white rounded-xl p-3 border border-slate-100">
            <p class="text-[10px] font-bold text-slate-400 mb-1">Email Identifier</p>
            <p class="text-xs font-semibold text-slate-700 truncate">
              <%= admin.email %>
            </p>
          </div>
        </div>

        <div class="p-3">
          <form method="POST" action="/admin/logout">
            <button type="submit"
              class="w-full flex items-center justify-between px-6 py-4 rounded-[1.5rem] bg-slate-50 hover:bg-rose-50 border border-transparent hover:border-rose-100 transition-all duration-300 group">
              <div class="flex items-center gap-3">
                <div class="p-2 bg-white rounded-xl group-hover:bg-rose-100 transition-colors shadow-sm">
                  <svg class="w-4 h-4 text-slate-400 group-hover:text-rose-600" fill="none" stroke="currentColor"
                    viewBox="0 0 24 24" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round"
                      d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                  </svg>
                </div>
                <span
                  class="text-xs font-black text-slate-600 group-hover:text-rose-700 uppercase tracking-widest">Secure
                  Logout</span>
              </div>
              <svg class="w-4 h-4 text-slate-300 group-hover:text-rose-400" fill="none" stroke="currentColor"
                viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const dropdownBtn = document.getElementById('adminDropdownBtn');
  const dropdownMenu = document.getElementById('adminDropdownMenu');
  const notificationBtn = document.getElementById('notificationBtn');
  const notificationMenu = document.getElementById('notificationMenu');
  const notificationList = document.getElementById('notificationList');
  const notificationEmpty = document.getElementById('notificationEmpty');
  const notificationBadge = document.getElementById('notificationBadge');
  const sidebarToggle = document.getElementById('sidebarToggle');
  const sidebarToggleDesktop = document.getElementById('sidebarToggleDesktop');

  let notificationCache = [];
  let notificationPollTimer = null;
  let notificationFetchInFlight = false;

  function closeAdminDropdown() {
    dropdownMenu.classList.remove('opacity-100', 'scale-100');
    setTimeout(() => dropdownMenu.classList.add('hidden'), 300);
  }

  function closeNotificationDropdown() {
    if (!notificationMenu) return;
    notificationMenu.classList.remove('opacity-100', 'scale-100');
    setTimeout(() => notificationMenu.classList.add('hidden'), 300);
  }

  function openNotificationDropdown() {
    if (!notificationMenu) return;
    notificationMenu.classList.remove('hidden');
    setTimeout(() => notificationMenu.classList.add('opacity-100', 'scale-100'), 10);

    // Mark currently visible unread notifications as read (non-blocking)
    const unreadIds = (notificationCache || []).filter(n => n.unread).map(n => n.id);
    if (unreadIds.length) {
      fetch('/api/notifications/mark-read', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8' },
        body: new URLSearchParams({ ids: unreadIds.join(',') }).toString()
      }).catch(() => { });
    }
  }

  function formatTime(ms) {
    if (!ms) return '';
    const diff = Date.now() - ms;
    const sec = Math.floor(diff / 1000);
    if (sec < 60) return `${sec}s ago`;
    const min = Math.floor(sec / 60);
    if (min < 60) return `${min}m ago`;
    const hr = Math.floor(min / 60);
    if (hr < 24) return `${hr}h ago`;
    const d = Math.floor(hr / 24);
    return `${d}d ago`;
  }

  function renderNotifications(data) {
    const items = (data?.notifications || []).slice().sort((a, b) => (b.createdAtMs || 0) - (a.createdAtMs || 0));
    notificationCache = items;

    const unreadCount = data?.unreadCount ?? items.filter(i => i.unread).length;
    if (notificationBadge) {
      if (unreadCount > 0) {
        notificationBadge.textContent = unreadCount > 99 ? '99+' : String(unreadCount);
        notificationBadge.classList.remove('hidden');
      } else {
        notificationBadge.classList.add('hidden');
      }
    }

    if (!notificationList) return;
    notificationList.innerHTML = '';

    if (!items.length) {
      if (notificationEmpty) notificationEmpty.classList.remove('hidden');
      return;
    }
    if (notificationEmpty) notificationEmpty.classList.add('hidden');

    items.forEach((n) => {
      const row = document.createElement('div');
      row.className = `px-8 py-5 hover:bg-slate-50/50 transition-colors cursor-pointer ${n.unread ? 'bg-emerald-50/40' : ''}`;

      const title = (n.title || 'Notification').toString();
      const msg = (n.message || '').toString();
      const time = formatTime(n.createdAtMs);

      row.onclick = () => {
        if (n.orderId) {
          window.location.href = `/admin/orders/view/${n.orderId}`;
        }
      };

      row.innerHTML = `
        <div class="flex items-start gap-3">
          <div class="mt-1.5 w-2 h-2 rounded-full ${n.unread ? 'bg-emerald-500' : 'bg-slate-200'}"></div>
          <div class="flex-1 min-w-0">
            <p class="text-xs font-black text-slate-900 truncate">${title}</p>
            <p class="text-[10px] font-medium text-slate-500 mt-1 leading-relaxed">${msg}</p>
            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mt-2">${time}</p>
          </div>
        </div>
      `;
      notificationList.appendChild(row);
    });
  }

  async function fetchNotifications() {
    if (notificationFetchInFlight) return;
    notificationFetchInFlight = true;
    try {
      const res = await fetch('/api/notifications?limit=10', { cache: 'no-store' });
      const data = await res.json();
      renderNotifications(data);
    } catch (e) {
      // silent failure (do not disturb UI)
    } finally {
      notificationFetchInFlight = false;
    }
  }

  function startNotificationPolling() {
    if (notificationPollTimer) return;
    fetchNotifications();
    notificationPollTimer = setInterval(fetchNotifications, 5000);
  }

  // Logic remains robust but animations are cleaner
  dropdownBtn.onclick = (e) => {
    e.stopPropagation();
    const isHidden = dropdownMenu.classList.contains('hidden');
    if (isHidden) {
      dropdownMenu.classList.remove('hidden');
      setTimeout(() => dropdownMenu.classList.add('opacity-100', 'scale-100'), 10);
    } else {
      closeAdminDropdown();
    }
  };

  if (notificationBtn) {
    startNotificationPolling();
    notificationBtn.onclick = (e) => {
      e.stopPropagation();
      // Close admin dropdown if open
      closeAdminDropdown();
      const isHidden = notificationMenu.classList.contains('hidden');
      if (isHidden) openNotificationDropdown();
      else closeNotificationDropdown();
    };
  }

  window.onclick = () => {
    closeAdminDropdown();
    closeNotificationDropdown();
  };

  function toggleSidebar() {
    const sidebar = document.getElementById('sidebar');
    const backdrop = document.getElementById('sidebarBackdrop');
    if (!sidebar) return;

    const isMobile = window.innerWidth < 768;

    if (isMobile) {
      const isOpen = !sidebar.classList.contains('-translate-x-full');
      if (isOpen) {
        // Close
        sidebar.classList.add('-translate-x-full');
        if (backdrop) {
          backdrop.classList.add('opacity-0');
          setTimeout(() => backdrop.classList.add('hidden'), 300);
        }
      } else {
        // Open
        sidebar.classList.remove('-translate-x-full');
        if (backdrop) {
          backdrop.classList.remove('hidden');
          setTimeout(() => backdrop.classList.remove('opacity-0'), 10);
        }
      }
    } else {
      // Desktop: Toggle classes that force visibility and width
      const isCollapsed = sidebar.classList.contains('md:-translate-x-full');

      if (!isCollapsed) {
        // Collapse
        sidebar.classList.add('md:-translate-x-full', 'md:w-0');
        sidebar.classList.remove('md:translate-x-0', 'md:w-72');
        if (sidebarToggleDesktop) {
          sidebarToggleDesktop.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 17l5-5m0 0l-5-5m5 5H6" /></svg>`;
        }
      } else {
        // Expand
        sidebar.classList.remove('md:-translate-x-full', 'md:w-0');
        sidebar.classList.add('md:translate-x-0', 'md:w-72');
        if (sidebarToggleDesktop) {
          sidebarToggleDesktop.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11 17l-5-5m0 0l5-5m-5 5h12" /></svg>`;
        }
      }
    }
  }

  // Close sidebar on backdrop click (mobile)
  const backdrop = document.getElementById('sidebarBackdrop');
  if (backdrop) {
    backdrop.onclick = () => {
      const sidebar = document.getElementById('sidebar');
      if (sidebar && !sidebar.classList.contains('-translate-x-full')) {
        toggleSidebar();
      }
    }
  }

  if (sidebarToggle) sidebarToggle.onclick = toggleSidebar;
  if (sidebarToggleDesktop) sidebarToggleDesktop.onclick = toggleSidebar;
</script>