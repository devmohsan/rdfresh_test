<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Rdfresh Admin Dashboard</title>
  <link href="/css/output.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/dayjs@1/dayjs.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-dayjs@1"></script>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <style>
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-entry {
      animation: fadeIn 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
      opacity: 0;
    }

    .delay-1 {
      animation-delay: 0.1s;
    }

    .delay-2 {
      animation-delay: 0.2s;
    }

    .delay-3 {
      animation-delay: 0.3s;
    }

    .delay-4 {
      animation-delay: 0.4s;
    }
  </style>
</head>

<body class="bg-gray-50">
  <div class="flex h-screen overflow-hidden">
    <%- include('partials/sidebar') %>

      <div class="flex flex-col flex-1 overflow-x-hidden overflow-y-auto">
        <%- include('partials/header') %>
          <main class="p-6">
            <!-- Welcome Header -->
            <div class="relative bg-slate-900 rounded-[2rem] overflow-hidden mb-10 shadow-2xl animate-entry">
              <!-- Pattern overlay -->
              <div class="absolute inset-0 opacity-10 pointer-events-none">
                <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
                  <defs>
                    <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
                      <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1" />
                    </pattern>
                  </defs>
                  <rect width="100%" height="100%" fill="url(#grid)" />
                </svg>
              </div>

              <div class="relative px-10 py-12 flex flex-col md:flex-row md:items-center justify-between gap-6">
                <div>
                  <h1 class="text-4xl font-extrabold text-white tracking-tight mb-2">
                    Welcome back, <span class="text-emerald-400">
                      <%= admin.name || 'Administrator' %>
                    </span>
                  </h1>
                  <p class="text-slate-400 font-medium text-lg">
                    Rdfresh business statistics for today.
                  </p>
                </div>
                <div class="flex items-center gap-4">
                  <div class="bg-white/5 backdrop-blur-md rounded-2xl px-6 py-4 border border-white/10 shadow-inner">
                    <p class="text-xs font-bold text-emerald-400 uppercase tracking-widest mb-1">Current Date</p>
                    <p class="text-white font-semibold">
                      <%= new Date().toLocaleDateString('en-US', { weekday: 'long' , year: 'numeric' , month: 'long' ,
                        day: 'numeric' }) %>
                    </p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Stats Cards Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-10">
              <!-- Total Orders Card -->
              <div
                class="group bg-white rounded-[2rem] p-8 shadow-[0_20px_50px_rgba(0,0,0,0.04)] border border-slate-100 hover:shadow-emerald-500/10 hover:border-emerald-100 transition-all duration-300 animate-entry delay-1">
                <div class="flex items-start justify-between mb-8">
                  <div
                    class="w-14 h-14 bg-slate-900 rounded-2xl flex items-center justify-center shadow-lg group-hover:bg-emerald-500 transition-colors duration-300">
                    <svg class="w-6 h-6 text-emerald-400 group-hover:text-white" fill="none" stroke="currentColor"
                      viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                    </svg>
                  </div>
                  <div class="flex flex-col items-end">
                    <span class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Performance</span>
                    <span class="text-emerald-500 font-bold bg-emerald-50 px-3 py-1 rounded-full text-xs">
                      +<%= dashboard.todayOrders %> Today
                    </span>
                  </div>
                </div>
                <div>
                  <h3 class="text-3xl font-black text-slate-900 mb-1 tracking-tight">
                    <%= dashboard.totalOrders %>
                  </h3>
                  <p class="text-slate-500 font-semibold text-sm">Total Orders Received</p>
                </div>
                <div class="mt-6 pt-6 border-t border-slate-50 flex items-center gap-4">
                  <div class="flex items-center text-xs font-bold">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 mr-2"></span>
                    <span class="text-emerald-600">
                      <%= dashboard.completedOrders %> Completed
                    </span>
                  </div>
                  <div class="flex items-center text-xs font-bold">
                    <span class="w-2 h-2 rounded-full bg-amber-400 mr-2"></span>
                    <span class="text-amber-600">
                      <%= dashboard.pendingOrders %> Pending
                    </span>
                  </div>
                </div>
              </div>

              <!-- Revenue Card -->
              <div
                class="group bg-white rounded-[2rem] p-8 shadow-[0_20px_50px_rgba(0,0,0,0.04)] border border-slate-100 hover:shadow-emerald-500/10 hover:border-emerald-100 transition-all duration-300 animate-entry delay-2">
                <div class="flex items-start justify-between mb-8">
                  <div
                    class="w-14 h-14 bg-slate-900 rounded-2xl flex items-center justify-center shadow-lg group-hover:bg-emerald-500 transition-colors duration-300">
                    <svg class="w-6 h-6 text-emerald-400 group-hover:text-white" fill="none" stroke="currentColor"
                      viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                  <div class="flex flex-col items-end">
                    <span class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Growth</span>
                    <span class="text-emerald-500 font-bold bg-emerald-50 px-3 py-1 rounded-full text-xs">
                      Live Stats
                    </span>
                  </div>
                </div>
                <div>
                  <h3 class="text-3xl font-black text-slate-900 mb-1 tracking-tight">$<%= dashboard.totalRevenue %>
                  </h3>
                  <p class="text-slate-500 font-semibold text-sm">Total Revenue Generated</p>
                </div>
                <div class="mt-6 pt-6 border-t border-slate-50">
                  <p class="text-xs text-slate-400 font-bold uppercase tracking-wider">Analysis</p>
                  <p class="text-xs text-slate-600 font-semibold mt-1">Based on <%= dashboard.totalOrders %> processed
                      transactions</p>
                </div>
              </div>

              <!-- Users Card -->
              <div
                class="group bg-white rounded-[2rem] p-8 shadow-[0_20px_50px_rgba(0,0,0,0.04)] border border-slate-100 hover:shadow-emerald-500/10 hover:border-emerald-100 transition-all duration-300 animate-entry delay-3">
                <div class="flex items-start justify-between mb-8">
                  <div
                    class="w-14 h-14 bg-slate-900 rounded-2xl flex items-center justify-center shadow-lg group-hover:bg-emerald-500 transition-colors duration-300">
                    <svg class="w-6 h-6 text-emerald-400 group-hover:text-white" fill="none" stroke="currentColor"
                      viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                  </div>
                  <div class="flex flex-col items-end">
                    <span class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">Network</span>
                    <span class="text-emerald-500 font-bold bg-emerald-50 px-3 py-1 rounded-full text-xs">
                      <%= dashboard.approvedUsers %> Active
                    </span>
                  </div>
                </div>
                <div>
                  <h3 class="text-3xl font-black text-slate-900 mb-1 tracking-tight">
                    <%= dashboard.totalUsers %>
                  </h3>
                  <p class="text-slate-500 font-semibold text-sm">Registered User Base</p>
                </div>
                <div class="mt-6 pt-6 border-t border-slate-50 flex items-center gap-4">
                  <div class="flex items-center text-xs font-bold">
                    <span class="w-2 h-2 rounded-full bg-emerald-500 mr-2"></span>
                    <span class="text-emerald-600">
                      <%= dashboard.approvedUsers %> Approved
                    </span>
                  </div>
                  <div class="flex items-center text-xs font-bold">
                    <span class="w-2 h-2 rounded-full bg-rose-400 mr-2"></span>
                    <span class="text-rose-600">
                      <%= dashboard.pendingUsers %> Pending
                    </span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Detailed Tables Section -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
              <!-- Recent Orders Table -->
              <div
                class="bg-white rounded-[2.5rem] shadow-[0_20px_60px_rgba(0,0,0,0.03)] border border-slate-100 overflow-hidden">
                <div class="px-8 py-6 border-b border-slate-50 flex items-center justify-between bg-slate-50/50">
                  <h2 class="text-xl font-black text-slate-900 flex items-center gap-3">
                    <div class="w-2 h-6 bg-emerald-500 rounded-full"></div>
                    Recent Orders
                  </h2>
                  <a href="/admin/orders"
                    class="text-xs font-bold text-emerald-600 uppercase tracking-widest hover:text-emerald-700 transition-colors">View
                    All</a>
                </div>
                <div class="p-8">
                  <% if (dashboard.recentOrders.length===0) { %>
                    <div class="text-center py-12">
                      <div class="inline-flex p-6 bg-slate-50 rounded-full mb-4">
                        <svg class="w-10 h-10 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                        </svg>
                      </div>
                      <p class="text-slate-400 font-bold">No active orders found</p>
                    </div>
                    <% } else { %>
                      <div class="space-y-4">
                        <% dashboard.recentOrders.forEach(order=> { %>
                          <div
                            class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl hover:bg-white hover:shadow-xl hover:shadow-slate-200/50 transition-all duration-300 group cursor-pointer border border-transparent hover:border-slate-100">
                            <div class="flex items-center gap-4">
                              <div
                                class="w-12 h-12 bg-white rounded-xl flex items-center justify-center shadow-sm text-lg font-black text-slate-900 group-hover:bg-emerald-500 group-hover:text-white transition-all">
                                #<%= order.id.slice(0, 1).toUpperCase() %>
                              </div>
                              <div>
                                <p class="text-sm font-bold text-slate-900">Order #<%= order.id.slice(0, 8) %>
                                </p>
                                <p class="text-xs font-semibold text-slate-400">
                                  <%= order.createdAt ? new Date(order.createdAt.seconds * 1000).toLocaleDateString()
                                    : 'Just now' %>
                                </p>
                              </div>
                            </div>
                            <div class="text-right">
                              <p class="text-sm font-black text-slate-900 mb-1">$<%= order.total_amount || '0.00' %>
                              </p>
                              <span
                                class="inline-block px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-wider <%= order.status === 'completed' ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>">
                                <%= order.status || 'Pending' %>
                              </span>
                            </div>
                          </div>
                          <% }); %>
                      </div>
                      <% } %>
                </div>
              </div>

              <!-- Recent Users Table -->
              <div
                class="bg-white rounded-[2.5rem] shadow-[0_20px_60px_rgba(0,0,0,0.03)] border border-slate-100 overflow-hidden">
                <div class="px-8 py-6 border-b border-slate-50 flex items-center justify-between bg-slate-50/50">
                  <h2 class="text-xl font-black text-slate-900 flex items-center gap-3">
                    <div class="w-2 h-6 bg-emerald-500 rounded-full"></div>
                    Recent Users
                  </h2>
                  <a href="/admin/users"
                    class="text-xs font-bold text-emerald-600 uppercase tracking-widest hover:text-emerald-700 transition-colors">Manage</a>
                </div>
                <div class="p-8">
                  <% if (dashboard.recentUsers.length===0) { %>
                    <div class="text-center py-12">
                      <div class="inline-flex p-6 bg-slate-50 rounded-full mb-4">
                        <svg class="w-10 h-10 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                        </svg>
                      </div>
                      <p class="text-slate-400 font-bold">No recent users joined</p>
                    </div>
                    <% } else { %>
                      <div class="space-y-4">
                        <% dashboard.recentUsers.forEach(user=> { %>
                          <div
                            class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl hover:bg-white hover:shadow-xl hover:shadow-slate-200/50 transition-all duration-300 group cursor-pointer border border-transparent hover:border-slate-100">
                            <div class="flex items-center gap-4">
                              <div
                                class="w-12 h-12 bg-slate-900 rounded-xl flex items-center justify-center shadow-lg group-hover:bg-emerald-500 transition-all duration-300">
                                <%= (user.name || 'U' ).charAt(0).toUpperCase() %>
                              </div>
                              <div>
                                <p class="text-sm font-bold text-slate-900">
                                  <%= user.name || 'External User' %>
                                </p>
                                <p class="text-xs font-semibold text-slate-400">
                                  <%= user.email || 'N/A' %>
                                </p>
                              </div>
                            </div>
                            <div class="text-right">
                              <% if (user.companyName) { %>
                                <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter mb-1">
                                  <%= user.companyName %>
                                </p>
                                <% } %>
                                  <span
                                    class="inline-block px-3 py-1 rounded-lg text-[10px] font-black uppercase tracking-wider <%= user.status === 'approved' ? 'bg-emerald-100 text-emerald-700' : 'bg-rose-100 text-rose-700' %>">
                                    <%= user.status || 'Pending' %>
                                  </span>
                            </div>
                          </div>
                          <% }); %>
                      </div>
                      <% } %>
                </div>
              </div>
            </div>

          </main>
      </div>
  </div>

  <%- include('partials/script') %>
</body>

</html>