<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rdfresh | Product Management</title>
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .animate-entry {
            animation: fadeIn 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
            opacity: 0;
        }

        .delay-1 {
            animation-delay: 0.1s;
        }

        .delay-2 {
            animation-delay: 0.2s;
        }
    </style>
</head>

<body class="bg-[#F8FAFC]">
    <div class="flex h-screen overflow-hidden">
        <%- include('partials/sidebar') %>

            <div class="relative flex flex-col flex-1 overflow-x-hidden overflow-y-auto">
                <%- include('partials/header') %>

                    <main class="flex-1 p-8">
                        <div class="max-w-7xl mx-auto">
                            <!-- Premium Header Section -->
                            <div
                                class="flex flex-col md:flex-row md:items-end justify-between mb-10 gap-6 animate-entry">
                                <div>
                                    <nav class="flex mb-4" aria-label="Breadcrumb">
                                        <ol
                                            class="inline-flex items-center space-x-1 md:space-x-3 text-xs font-bold uppercase tracking-widest">
                                            <li class="inline-flex items-center">
                                                <a href="/admin/dashboard"
                                                    class="text-slate-400 hover:text-emerald-500 transition-colors">Dashboard</a>
                                            </li>
                                            <li>
                                                <div class="flex items-center">
                                                    <svg class="w-3 h-3 text-slate-300 mx-1" fill="currentColor"
                                                        viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd"
                                                            d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                                                            clip-rule="evenodd"></path>
                                                    </svg>
                                                    <span class="text-slate-900">Products</span>
                                                </div>
                                            </li>
                                        </ol>
                                    </nav>
                                    <h1 class="text-4xl font-black text-slate-900 tracking-tight">Product Inventory</h1>
                                    <p class="text-slate-500 mt-2 font-medium">Manage your professional refrigeration
                                        solutions catalogue.</p>
                                </div>

                                <div class="flex items-center gap-3">
                                    <div class="flex items-center gap-3"></div>
              <a href="/admin/products/add" class="flex items-center gap-3 px-8 py-4 bg-emerald-500 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-emerald-600 transition-all shadow-lg shadow-emerald-200">
                <i class="fas fa-plus"></i>
                Create New SKU
              </a>
              <div class="bg-white p-2 rounded-2xl shadow-sm border border-slate-100 flex items-center gap-2 px-4 py-3">
                                        <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                                        <span class="text-xs font-black text-slate-700 uppercase tracking-widest">
                                            <%= products.length %> Total SKU's
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <!-- Product Grid -->
                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 animate-entry delay-1">
                                <% if (products.length===0) { %>
                                    <div
                                        class="col-span-full py-20 text-center bg-white rounded-[2.5rem] border border-dashed border-slate-200">
                                        <div
                                            class="w-16 h-16 bg-slate-50 rounded-full flex items-center justify-center text-slate-300 mb-4 mx-auto">
                                            <i class="fas fa-box-open text-2xl"></i>
                                        </div>
                                        <p class="text-slate-400 font-bold uppercase tracking-widest">No products found
                                            in inventory</p>
                                    </div>
                                    <% } else { %>
                                        <% products.forEach(product=> { %>
                                            <div
                                                class="bg-white rounded-[2.5rem] border border-slate-100 shadow-[0_20px_50px_rgba(0,0,0,0.02)] overflow-hidden group hover:shadow-xl hover:shadow-slate-200/50 transition-all duration-300 flex flex-col">
                                                <!-- Product Image -->
                                                <div class="h-56 bg-slate-100 relative overflow-hidden">
                                                    <img src="<%= product.imageUrl || 'https://images.unsplash.com/photo-1542838132-92c53300491e?auto=format&fit=crop&q=80&w=600' %>"
                                                        alt="<%= product.name %>"
                                                        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                                                    <div class="absolute top-4 right-4">
                                                        <span class="inline-flex items-center px-3 py-1.5 rounded-xl text-[10px] font-black uppercase tracking-wider shadow-lg
                        <%= product.active ? 'bg-emerald-500 text-white' : 'bg-rose-500 text-white' %>">
                                                            <%= product.active ? 'Active' : 'Inactive' %>
                                                        </span>
                                                    </div>
                                                </div>

                                                <!-- Product Info -->
                                                <div class="p-8 flex-grow flex flex-col">
                                                    <div class="flex justify-between items-start mb-4">
                                                        <div>
                                                            <h3 class="text-xl font-black text-slate-900 line-clamp-1">
                                                                <%= product.name %>
                                                            </h3>
                                                            <p
                                                                class="text-[10px] font-black text-emerald-600 uppercase tracking-widest mt-1">
                                                                SKU: <%= product.sku || 'N/A' %>
                                                            </p>
                                                        </div>
                                                        <div class="text-right">
                                                            <p class="text-xl font-black text-slate-900">$<%=
                                                                    parseFloat(product.price || 0).toFixed(2) %>
                                                            </p>
                                                        </div>
                                                    </div>

                                                    <p
                                                        class="text-slate-500 text-sm font-medium mb-6 line-clamp-2 leading-relaxed flex-grow">
                                                        <%= product.internalNotes
                                                            || 'Professional refrigeration solution designed for high-performance environments.'
                                                            %>
                                                    </p>

                                                    <div class="flex items-center gap-3 mt-auto">
                                                        <form action="/admin/products/toggle-status/<%= product.id %>"
                                                            method="POST" class="flex-grow">
                                                            <button type="submit" class="w-full py-3.5 rounded-2xl font-black text-[10px] uppercase tracking-widest transition-all
                          <%= product.active ? 'bg-rose-50 text-rose-600 hover:bg-rose-100 border border-rose-100' : 'bg-emerald-50 text-emerald-600 hover:bg-emerald-100 border border-emerald-100' %>">
                                                                <%= product.active ? 'Deactivate Listing'
                                                                    : 'Activate Listing' %>
                                                            </button>
                                                        </form>
                                                        <a href="/admin/products/edit/<%= product.id %>" class="p-3.5 bg-slate-900 text-emerald-400 rounded-2xl hover:bg-emerald-500 hover:text-white transition-all shadow-lg group/edit">
                                                            <i
                                                                class="fas fa-edit transition-transform group-hover/edit:scale-110"></i>
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                            <% }); %>
                                                <% } %>
                            </div>
                        </div>
                    </main>
            </div>
    </div>

    <%- include('partials/script') %>
</body>

</html>